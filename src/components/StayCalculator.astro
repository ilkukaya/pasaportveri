---
---

<div class="bg-white rounded-xl border border-slate-200 p-6" id="stay-calculator">
  <h2 class="text-xl font-bold text-slate-900 mb-2">Kaç Gün Kalabilirim?</h2>
  <p class="text-sm text-slate-500 mb-6">Ülke seçin ve giriş tarihinizi girin, size maksimum kalış sürenizi ve önerilen çıkış tarihini gösterelim.</p>

  <div class="space-y-4">
    <div>
      <label for="calc-country" class="block text-sm font-medium text-slate-700 mb-1">Ülke Seçin</label>
      <select id="calc-country" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-secondary focus:border-secondary">
        <option value="">-- Ülke seçin --</option>
      </select>
    </div>

    <div>
      <label for="calc-entry" class="block text-sm font-medium text-slate-700 mb-1">Giriş Tarihi</label>
      <input type="date" id="calc-entry" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-secondary focus:border-secondary" />
    </div>

    <button id="calc-btn" class="w-full bg-secondary text-white py-2.5 rounded-lg font-medium hover:bg-slate-800 transition-colors text-sm">
      Hesapla
    </button>

    <div id="calc-result" class="hidden mt-4 p-4 rounded-lg bg-slate-50 border border-slate-200">
    </div>
  </div>
</div>

<script>
  interface CountryData {
    name_tr: string;
    slug: string;
    visa_status: string;
    visa_status_tr: string;
    max_stay_days: number | null;
  }

  let countries: CountryData[] = [];

  fetch('/data/passport_data.json')
    .then(r => r.json())
    .then(data => {
      countries = data.countries.map((c: any) => ({
        name_tr: c.name_tr,
        slug: c.slug,
        visa_status: c.visa_status,
        visa_status_tr: c.visa_status_tr,
        max_stay_days: c.max_stay_days
      }));

      const select = document.getElementById('calc-country') as HTMLSelectElement;
      countries.sort((a, b) => a.name_tr.localeCompare(b.name_tr, 'tr')).forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.slug;
        opt.textContent = `${c.name_tr} (${c.visa_status_tr}${c.max_stay_days ? ` - ${c.max_stay_days} gün` : ''})`;
        select.appendChild(opt);
      });
    })
    .catch(() => {});

  document.getElementById('calc-btn')?.addEventListener('click', () => {
    const select = document.getElementById('calc-country') as HTMLSelectElement;
    const entryInput = document.getElementById('calc-entry') as HTMLInputElement;
    const result = document.getElementById('calc-result');

    if (!select.value || !entryInput.value || !result) return;

    const country = countries.find(c => c.slug === select.value);
    if (!country) return;

    const entryDate = new Date(entryInput.value);
    const maxDays = country.max_stay_days;

    let exitDate: Date | null = null;
    let stayText = '';

    if (maxDays) {
      exitDate = new Date(entryDate.getTime() + maxDays * 24 * 60 * 60 * 1000);
      stayText = `Maksimum ${maxDays} gün kalabilirsiniz.`;
    } else if (country.visa_status === 'visa_required') {
      stayText = 'Vize gerekli. Vize başvurusu sırasında kalış sürenizi belirtmelisiniz.';
    } else {
      stayText = 'Bu ülke için belirtilmiş maksimum kalış süresi bulunmamaktadır. Güncel bilgi için büyükelçilik ile iletişime geçin.';
    }

    const options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
    const entryFormatted = entryDate.toLocaleDateString('tr-TR', options);
    const exitFormatted = exitDate ? exitDate.toLocaleDateString('tr-TR', options) : '-';

    const statusColors: Record<string, string> = {
      visa_free: 'bg-green-50 border-green-200 text-green-800',
      visa_on_arrival: 'bg-amber-50 border-amber-200 text-amber-800',
      e_visa: 'bg-blue-50 border-blue-200 text-blue-800',
      visa_required: 'bg-red-50 border-red-200 text-red-800'
    };

    result.className = `mt-4 p-4 rounded-lg border ${statusColors[country.visa_status] || 'bg-slate-50 border-slate-200'}`;
    result.innerHTML = `
      <div class="font-semibold mb-2">${country.name_tr}</div>
      <div class="text-sm space-y-1">
        <p>Vize Durumu: <strong>${country.visa_status_tr}</strong></p>
        <p>Giriş Tarihi: <strong>${entryFormatted}</strong></p>
        <p>Önerilen Çıkış Tarihi: <strong>${exitFormatted}</strong></p>
        <p class="mt-2">${stayText}</p>
      </div>
    `;
    result.classList.remove('hidden');
  });
</script>
