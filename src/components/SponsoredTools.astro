---
/**
 * SponsoredTools - Natural "Travel Tools" section that shows active affiliate programs
 * as helpful travel tools. Integrates naturally with the travel content.
 */
import affiliateData from '../data/affiliate_programs.json';

interface Props {
  countryName?: string;
  /** max number of programs to show */
  limit?: number;
  /** section title override */
  title?: string;
  /** compact grid (sidebar) or full-width cards */
  variant?: 'grid' | 'compact' | 'inline';
}

const { countryName, limit = 6, title, variant = 'grid' } = Astro.props;

const activePrograms = affiliateData.programs
  .filter(p => p.active && p.url)
  .sort((a, b) => a.sort_order - b.sort_order)
  .slice(0, limit);

if (activePrograms.length === 0) return;

const iconMap: Record<string, string> = {
  shield: '🛡️',
  smartphone: '📱',
  building: '🏨',
  plane: '✈️',
  car: '🚗',
  compass: '🧭',
  key: '🔑',
  lock: '🔒',
  banknote: '💰',
  ticket: '🎫',
};

const colorMap: Record<string, { bg: string; border: string; text: string; badge: string; hover: string }> = {
  emerald: { bg: 'bg-emerald-50', border: 'border-emerald-200', text: 'text-emerald-700', badge: 'bg-emerald-100 text-emerald-800', hover: 'hover:border-emerald-300 hover:shadow-emerald-100' },
  violet: { bg: 'bg-violet-50', border: 'border-violet-200', text: 'text-violet-700', badge: 'bg-violet-100 text-violet-800', hover: 'hover:border-violet-300 hover:shadow-violet-100' },
  blue: { bg: 'bg-blue-50', border: 'border-blue-200', text: 'text-blue-700', badge: 'bg-blue-100 text-blue-800', hover: 'hover:border-blue-300 hover:shadow-blue-100' },
  sky: { bg: 'bg-sky-50', border: 'border-sky-200', text: 'text-sky-700', badge: 'bg-sky-100 text-sky-800', hover: 'hover:border-sky-300 hover:shadow-sky-100' },
  amber: { bg: 'bg-amber-50', border: 'border-amber-200', text: 'text-amber-700', badge: 'bg-amber-100 text-amber-800', hover: 'hover:border-amber-300 hover:shadow-amber-100' },
  orange: { bg: 'bg-orange-50', border: 'border-orange-200', text: 'text-orange-700', badge: 'bg-orange-100 text-orange-800', hover: 'hover:border-orange-300 hover:shadow-orange-100' },
  rose: { bg: 'bg-rose-50', border: 'border-rose-200', text: 'text-rose-700', badge: 'bg-rose-100 text-rose-800', hover: 'hover:border-rose-300 hover:shadow-rose-100' },
  indigo: { bg: 'bg-indigo-50', border: 'border-indigo-200', text: 'text-indigo-700', badge: 'bg-indigo-100 text-indigo-800', hover: 'hover:border-indigo-300 hover:shadow-indigo-100' },
  teal: { bg: 'bg-teal-50', border: 'border-teal-200', text: 'text-teal-700', badge: 'bg-teal-100 text-teal-800', hover: 'hover:border-teal-300 hover:shadow-teal-100' },
  pink: { bg: 'bg-pink-50', border: 'border-pink-200', text: 'text-pink-700', badge: 'bg-pink-100 text-pink-800', hover: 'hover:border-pink-300 hover:shadow-pink-100' },
};

const sectionTitle = title || (countryName ? `${countryName} Seyahat Araclari` : 'Seyahat Araclari');
---

{variant === 'grid' && (
  <section class="my-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-slate-900">{sectionTitle}</h2>
      <span class="text-[10px] font-medium text-slate-400 uppercase tracking-wider bg-slate-100 px-2 py-0.5 rounded">Sponsorlu</span>
    </div>
    <div class={`grid gap-3 ${activePrograms.length <= 3 ? 'grid-cols-1 sm:grid-cols-' + activePrograms.length : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'}`}>
      {activePrograms.map(program => {
        const colors = colorMap[program.color] || colorMap.blue;
        const icon = iconMap[program.icon] || '🔗';
        const itemTitle = countryName && program.category !== 'vpn' && program.category !== 'compensation'
          ? `${countryName} ${program.category_tr}`
          : program.title_tr;
        return (
          <a
            href={program.url}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class={`group relative rounded-xl border ${colors.border} ${colors.bg} p-4 transition-all duration-200 ${colors.hover} hover:shadow-md`}
          >
            <div class="flex items-start gap-3">
              <span class="text-2xl flex-shrink-0 mt-0.5">{icon}</span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class={`font-semibold text-sm ${colors.text}`}>{itemTitle}</h3>
                </div>
                <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">{program.description_tr}</p>
                <div class="flex items-center justify-between mt-3">
                  <span class={`text-[10px] font-semibold ${colors.badge} px-2 py-0.5 rounded-full`}>{program.badge_tr}</span>
                  <span class={`text-xs font-semibold ${colors.text} group-hover:translate-x-0.5 transition-transform`}>
                    {program.cta_tr} →
                  </span>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

{variant === 'compact' && (
  <div class="space-y-2">
    <div class="flex items-center justify-between px-1 mb-1">
      <h3 class="font-bold text-slate-900 text-sm">{sectionTitle}</h3>
      <span class="text-[9px] font-medium text-slate-400 uppercase tracking-wider">Sponsorlu</span>
    </div>
    {activePrograms.map(program => {
      const colors = colorMap[program.color] || colorMap.blue;
      const icon = iconMap[program.icon] || '🔗';
      return (
        <a
          href={program.url}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="flex items-center gap-3 p-3 rounded-lg bg-slate-50 border border-slate-200 hover:border-slate-300 hover:bg-slate-100 transition-all group"
        >
          <span class="text-xl flex-shrink-0">{icon}</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-slate-900 group-hover:text-primary transition-colors truncate">{program.title_tr}</div>
            <div class="text-xs text-slate-500 truncate">{program.description_tr}</div>
          </div>
          <span class={`text-xs font-medium text-white bg-secondary px-2 py-1 rounded-full whitespace-nowrap flex-shrink-0`}>
            {program.cta_tr} →
          </span>
        </a>
      );
    })}
  </div>
)}

{variant === 'inline' && (
  <div class="my-6 bg-slate-50 border border-slate-200 rounded-xl p-5">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-semibold text-slate-900 text-sm">{sectionTitle}</h3>
      <span class="text-[9px] font-medium text-slate-400 uppercase tracking-wider bg-slate-200/60 px-2 py-0.5 rounded">Sponsorlu</span>
    </div>
    <div class="flex flex-wrap gap-2">
      {activePrograms.map(program => {
        const colors = colorMap[program.color] || colorMap.blue;
        const icon = iconMap[program.icon] || '🔗';
        return (
          <a
            href={program.url}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class={`inline-flex items-center gap-2 px-3 py-2 rounded-lg border ${colors.border} ${colors.bg} ${colors.hover} transition-all text-sm group`}
          >
            <span class="text-base">{icon}</span>
            <span class={`font-medium ${colors.text}`}>{program.name}</span>
            <span class="text-slate-400 group-hover:translate-x-0.5 transition-transform">→</span>
          </a>
        );
      })}
    </div>
  </div>
)}
