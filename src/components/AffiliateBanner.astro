---
import affiliateData from '../data/affiliate_programs.json';

interface Props {
  programId?: string;
  category?: string;
  countryName?: string;
  compact?: boolean;
}

const { programId, category, countryName, compact = false } = Astro.props;

// Find program by ID or category
let program = programId
  ? affiliateData.programs.find(p => p.id === programId && p.active)
  : category
  ? affiliateData.programs.find(p => p.category === category && p.active)
  : null;

// Fallback: if no active program found for this category, skip render
if (!program || !program.url) return;

const colorMap: Record<string, { gradient: string; bgLight: string }> = {
  emerald: { gradient: 'from-emerald-600 to-teal-700', bgLight: 'bg-emerald-50' },
  violet: { gradient: 'from-violet-600 to-purple-700', bgLight: 'bg-violet-50' },
  blue: { gradient: 'from-blue-600 to-indigo-700', bgLight: 'bg-blue-50' },
  sky: { gradient: 'from-sky-600 to-blue-700', bgLight: 'bg-sky-50' },
  amber: { gradient: 'from-amber-600 to-orange-700', bgLight: 'bg-amber-50' },
  orange: { gradient: 'from-orange-600 to-red-700', bgLight: 'bg-orange-50' },
  rose: { gradient: 'from-rose-600 to-pink-700', bgLight: 'bg-rose-50' },
  indigo: { gradient: 'from-indigo-600 to-blue-800', bgLight: 'bg-indigo-50' },
  teal: { gradient: 'from-teal-600 to-emerald-700', bgLight: 'bg-teal-50' },
  pink: { gradient: 'from-pink-600 to-rose-700', bgLight: 'bg-pink-50' },
};

const iconMap: Record<string, string> = {
  shield: '🛡️',
  smartphone: '📱',
  building: '🏨',
  plane: '✈️',
  car: '🚗',
  compass: '🧭',
  key: '🔑',
  lock: '🔒',
  banknote: '💰',
  ticket: '🎫',
};

const colors = colorMap[program.color] || colorMap.blue;
const icon = iconMap[program.icon] || '🔗';

// Contextual title with country name
const title = countryName && program.category !== 'vpn' && program.category !== 'compensation'
  ? `${countryName} ${program.title_tr}`
  : program.title_tr;

const description = countryName
  ? program.description_tr.replace('Yurt disi', `${countryName}`)
  : program.description_tr;
---

{compact ? (
  <a
    href={program.url}
    target="_blank"
    rel="noopener noreferrer nofollow"
    class="flex items-center gap-3 p-3 rounded-lg bg-slate-50 border border-slate-200 hover:border-slate-300 hover:bg-slate-100 transition-all group"
  >
    <span class="text-2xl flex-shrink-0">{icon}</span>
    <div class="flex-1 min-w-0">
      <div class="text-sm font-semibold text-slate-900 group-hover:text-primary transition-colors">{title}</div>
      <div class="text-xs text-slate-500 truncate">{program.description_tr}</div>
    </div>
    <span class="text-xs font-medium text-white bg-secondary px-2.5 py-1 rounded-full whitespace-nowrap flex-shrink-0">
      {program.cta_tr} &rarr;
    </span>
  </a>
) : (
  <div class={`affiliate-banner bg-gradient-to-r ${colors.gradient} rounded-xl overflow-hidden my-6 relative`}>
    <div class="absolute top-0 right-0 bg-white/20 backdrop-blur-sm text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-bl-lg">
      Sponsorlu
    </div>
    <div class="p-5 sm:p-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="flex items-start gap-3">
          <span class="text-3xl mt-0.5 flex-shrink-0">{icon}</span>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-bold text-lg text-white">{title}</h3>
              <span class="text-[10px] font-semibold bg-white/20 text-white px-2 py-0.5 rounded-full">{program.badge_tr}</span>
            </div>
            <p class="text-white/80 text-sm leading-relaxed">{description}</p>
          </div>
        </div>
        <a
          href={program.url}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="inline-flex items-center px-6 py-2.5 bg-white text-slate-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors whitespace-nowrap text-sm shadow-lg hover:shadow-xl"
        >
          {program.cta_tr} &rarr;
        </a>
      </div>
    </div>
  </div>
)}
