---
import rankingsData from '../data/passport_rankings.json';
import passportData from '../data/passport_data.json';

// Build a complete country name map from passport_data
const countryNames: Record<string, string> = {};
const countryFlags: Record<string, string> = {};
passportData.countries.forEach(c => {
  countryNames[c.code] = c.name_tr;
  countryFlags[c.code] = c.flag_emoji;
});

// Build passports array from rankings
const passports: Array<{ code: string; name: string; flag: string; rank: number; visa_free: number }> = [];
rankingsData.rankings.forEach(r => {
  r.passports.forEach(code => {
    passports.push({
      code,
      name: countryNames[code] || code,
      flag: countryFlags[code] || '',
      rank: r.rank,
      visa_free: r.visa_free_count
    });
  });
});
passports.sort((a, b) => a.name.localeCompare(b.name, 'tr'));
---

<div class="bg-white rounded-xl border border-slate-200 p-6" id="passport-comparator">
  <h2 class="text-xl font-bold text-slate-900 mb-2">Pasaport Karsilastir</h2>
  <p class="text-sm text-slate-500 mb-6">Iki pasaportu yan yana karsilastirin. Hangi pasaport daha guclu?</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div>
      <label for="compare-1" class="block text-sm font-medium text-slate-700 mb-1">1. Pasaport</label>
      <select id="compare-1" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-secondary focus:border-secondary">
        {passports.map(p => (
          <option value={p.code} selected={p.code === 'TR'}>
            {p.flag} {p.name} (#{p.rank})
          </option>
        ))}
      </select>
    </div>
    <div>
      <label for="compare-2" class="block text-sm font-medium text-slate-700 mb-1">2. Pasaport</label>
      <select id="compare-2" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-secondary focus:border-secondary">
        {passports.map(p => (
          <option value={p.code} selected={p.code === 'DE'}>
            {p.flag} {p.name} (#{p.rank})
          </option>
        ))}
      </select>
    </div>
  </div>

  <button id="compare-btn" class="w-full bg-secondary text-white py-2.5 rounded-lg font-medium hover:bg-slate-800 transition-colors text-sm mb-6">
    Karsilastir
  </button>

  <div id="compare-result" class="hidden">
  </div>
</div>

<script define:vars={{ passports }}>
  document.getElementById('compare-btn')?.addEventListener('click', () => {
    const sel1 = document.getElementById('compare-1');
    const sel2 = document.getElementById('compare-2');
    const result = document.getElementById('compare-result');

    if (!sel1.value || !sel2.value || !result) return;

    const p1 = passports.find(p => p.code === sel1.value);
    const p2 = passports.find(p => p.code === sel2.value);
    if (!p1 || !p2) return;

    const diff = p1.visa_free - p2.visa_free;
    const maxVF = Math.max(p1.visa_free, p2.visa_free, 1);
    const p1Pct = Math.round((p1.visa_free / 195) * 100);
    const p2Pct = Math.round((p2.visa_free / 195) * 100);

    let diffText = '';
    let diffClass = '';
    if (diff > 0) {
      diffText = p1.name + ', ' + Math.abs(diff) + ' ulke daha fazla vizesiz erisime sahip';
      diffClass = 'bg-green-50 border-green-200 text-green-800';
    } else if (diff < 0) {
      diffText = p2.name + ', ' + Math.abs(diff) + ' ulke daha fazla vizesiz erisime sahip';
      diffClass = 'bg-red-50 border-red-200 text-red-800';
    } else {
      diffText = 'Iki pasaport esit vizesiz erisime sahip';
      diffClass = 'bg-slate-50 border-slate-200 text-slate-800';
    }

    result.className = 'mt-4';
    result.innerHTML =
      '<div class="grid grid-cols-2 gap-4 mb-4">' +
        '<div class="text-center p-5 bg-slate-50 rounded-xl border border-slate-200">' +
          '<div class="text-3xl mb-2">' + p1.flag + '</div>' +
          '<div class="font-bold text-slate-900 text-lg">' + p1.name + '</div>' +
          '<div class="text-4xl font-extrabold text-secondary mt-2">#' + p1.rank + '</div>' +
          '<div class="text-sm text-slate-500 mt-1">' + p1.visa_free + ' ulke vizesiz</div>' +
          '<div class="mt-3 bg-slate-200 rounded-full h-2 overflow-hidden">' +
            '<div class="bg-green-500 h-full rounded-full" style="width: ' + p1Pct + '%"></div>' +
          '</div>' +
          '<div class="text-xs text-slate-400 mt-1">%' + p1Pct + ' erisim</div>' +
        '</div>' +
        '<div class="text-center p-5 bg-slate-50 rounded-xl border border-slate-200">' +
          '<div class="text-3xl mb-2">' + p2.flag + '</div>' +
          '<div class="font-bold text-slate-900 text-lg">' + p2.name + '</div>' +
          '<div class="text-4xl font-extrabold text-secondary mt-2">#' + p2.rank + '</div>' +
          '<div class="text-sm text-slate-500 mt-1">' + p2.visa_free + ' ulke vizesiz</div>' +
          '<div class="mt-3 bg-slate-200 rounded-full h-2 overflow-hidden">' +
            '<div class="bg-green-500 h-full rounded-full" style="width: ' + p2Pct + '%"></div>' +
          '</div>' +
          '<div class="text-xs text-slate-400 mt-1">%' + p2Pct + ' erisim</div>' +
        '</div>' +
      '</div>' +
      '<div class="p-3 rounded-lg border ' + diffClass + ' text-sm text-center font-medium">' + diffText + '</div>';
    result.classList.remove('hidden');
  });
</script>
