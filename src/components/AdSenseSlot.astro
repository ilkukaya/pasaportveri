---
/**
 * AdSense slot placeholder.
 * Set ADSENSE_PUB_ID in environment/build config to enable.
 * When the pub ID is not configured, this component renders nothing.
 */
interface Props {
  slot: string;
  format?: 'auto' | 'rectangle' | 'leaderboard' | 'skyscraper';
  fullWidth?: boolean;
}

const { slot, format = 'auto', fullWidth = false } = Astro.props;
const pubId = import.meta.env.PUBLIC_ADSENSE_PUB_ID || '';
const isEnabled = pubId && pubId !== 'ca-pub-ADSENSE_PUB_ID';
---

{isEnabled && (
  <div class={`adsense-wrapper ${fullWidth ? 'w-full' : ''}`} aria-label="Reklam">
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={pubId}
      data-ad-slot={slot}
      data-ad-format={format}
      data-full-width-responsive={fullWidth ? 'true' : 'false'}
    ></ins>
  </div>
)}
