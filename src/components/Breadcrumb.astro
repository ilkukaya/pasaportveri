---
interface Props {
  items: Array<{ label: string; href?: string }>;
}

const { items } = Astro.props;
---

<nav class="text-sm text-slate-500 mb-6" aria-label="Breadcrumb">
  <ol class="flex items-center flex-wrap gap-1">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && <span class="mx-1 text-slate-400" aria-hidden="true">/</span>}
        {item.href && index < items.length - 1 ? (
          <a href={item.href} class="hover:text-primary transition-colors">{item.label}</a>
        ) : (
          <span class={index === items.length - 1 ? 'text-slate-900 font-medium' : ''}>{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
