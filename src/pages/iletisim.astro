---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { generateCategoryMeta } from '../utils/seoHelpers';

const seo = generateCategoryMeta('iletisim');
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical} ogImage={seo.ogImage}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'İletişim' }
    ]} />

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-3">
        İletişim
      </h1>
      <p class="text-lg text-slate-600">
        Sorularınız, önerileriniz veya iş birliği talepleriniz için bize ulaşın.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Bize Ulaşın</h2>
        <div class="space-y-4 text-sm text-slate-700">
          <div class="flex items-center gap-3">
            <span class="text-2xl">📧</span>
            <div>
              <div class="font-medium text-slate-900">E-posta</div>
              <a href="mailto:info@pasaportveri.com" class="text-primary hover:underline">info@pasaportveri.com</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl">🐦</span>
            <div>
              <div class="font-medium text-slate-900">Twitter / X</div>
              <a href="https://twitter.com/pasaportveri" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">@pasaportveri</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl">📍</span>
            <div>
              <div class="font-medium text-slate-900">Konum</div>
              <div>İstanbul, Türkiye</div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Mesaj Gönderin</h2>
        <form class="space-y-4" action="https://formspree.io/f/FORM_ID" method="POST">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Adınız</label>
            <input type="text" id="name" name="name" required class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-secondary focus:border-secondary" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">E-posta</label>
            <input type="email" id="email" name="email" required class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-secondary focus:border-secondary" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-slate-700 mb-1">Mesajınız</label>
            <textarea id="message" name="message" rows="4" required class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-secondary focus:border-secondary"></textarea>
          </div>
          <button type="submit" class="w-full bg-secondary text-white py-2.5 rounded-lg font-medium hover:bg-slate-800 transition-colors text-sm">
            Gönder
          </button>
        </form>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-6 mt-8">
      <h2 class="text-lg font-bold text-slate-900 mb-4">Sıkça Sorulan Sorular</h2>
      <div class="space-y-4">
        {[
          { q: 'Veriler ne sıklıkla güncelleniyor?', a: 'Verilerimiz haftalık olarak otomatik güncellenmektedir. Ayrıca önemli değişikliklerde anlık güncelleme yapılır.' },
          { q: 'Hatalı bilgi buldum, nasıl bildirebilirim?', a: 'E-posta veya iletişim formu üzerinden bize ulaşabilirsiniz. En kısa sürede düzeltme yapılır.' },
          { q: 'İş birliği yapmak istiyorum.', a: 'Affiliate, reklam veya içerik iş birlikleri için info@pasaportveri.com adresine yazabilirsiniz.' }
        ].map(faq => (
          <details class="group border border-slate-200 rounded-lg">
            <summary class="cursor-pointer p-4 font-medium text-slate-900 hover:bg-slate-50 transition-colors list-none flex items-center justify-between">
              {faq.q}
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-4 pb-4 text-sm text-slate-600 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
