---
import passportData from '../data/passport_data.json';
import countriesMeta from '../data/countries_meta.json';
import affiliatePrograms from '../data/affiliate_programs.json';

const countries = passportData.countries;
const meta = (countriesMeta as any).countries;
const tp = passportData.turkish_passport;
---

<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>PV Admin Panel</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }

    /* Login */
    #login-screen { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-box { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 40px; max-width: 400px; width: 100%; }
    .login-box h1 { font-size: 24px; margin-bottom: 8px; color: #fff; }
    .login-box p { font-size: 14px; color: #94a3b8; margin-bottom: 24px; }
    .login-box input { width: 100%; padding: 12px 16px; background: #0f172a; border: 1px solid #475569; border-radius: 8px; color: #fff; font-size: 14px; margin-bottom: 16px; }
    .login-box input:focus { outline: none; border-color: #3b82f6; }
    .login-box button { width: 100%; padding: 12px; background: #3b82f6; color: #fff; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 14px; }
    .login-box button:hover { background: #2563eb; }
    .login-error { color: #ef4444; font-size: 13px; margin-bottom: 12px; display: none; }

    /* Dashboard */
    #dashboard { display: none; }
    .admin-header { background: #1e293b; border-bottom: 1px solid #334155; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .admin-header h1 { font-size: 18px; color: #fff; }
    .admin-header h1 span { color: #ef4444; }
    .btn-sm { padding: 8px 16px; border-radius: 6px; border: none; font-size: 13px; font-weight: 500; cursor: pointer; }
    .btn-danger { background: #ef4444; color: #fff; }
    .btn-danger:hover { background: #dc2626; }
    .btn-primary { background: #3b82f6; color: #fff; }
    .btn-primary:hover { background: #2563eb; }
    .btn-ghost { background: transparent; color: #94a3b8; border: 1px solid #475569; }
    .btn-ghost:hover { background: #1e293b; color: #fff; }

    .admin-body { display: flex; min-height: calc(100vh - 57px); }
    .sidebar { width: 240px; background: #1e293b; border-right: 1px solid #334155; padding: 16px; flex-shrink: 0; }
    .sidebar a { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border-radius: 8px; color: #94a3b8; text-decoration: none; font-size: 14px; margin-bottom: 4px; }
    .sidebar a:hover, .sidebar a.active { background: #334155; color: #fff; }
    .sidebar .section-title { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #475569; padding: 12px 12px 6px; font-weight: 600; }

    .content { flex: 1; padding: 24px; overflow-y: auto; }
    .content-section { display: none; }
    .content-section.active { display: block; }

    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 20px; margin-bottom: 16px; }
    .card h2 { font-size: 16px; color: #fff; margin-bottom: 12px; }
    .card h3 { font-size: 14px; color: #cbd5e1; margin-bottom: 8px; }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .stat-item { background: #0f172a; border: 1px solid #334155; border-radius: 10px; padding: 16px; }
    .stat-item .label { font-size: 12px; color: #94a3b8; margin-bottom: 4px; }
    .stat-item .value { font-size: 28px; font-weight: 700; }
    .stat-item .value.green { color: #22c55e; }
    .stat-item .value.amber { color: #f59e0b; }
    .stat-item .value.blue { color: #3b82f6; }
    .stat-item .value.red { color: #ef4444; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .data-table th { text-align: left; padding: 10px 12px; background: #0f172a; color: #94a3b8; font-weight: 600; border-bottom: 1px solid #334155; position: sticky; top: 0; }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid #1e293b; }
    .data-table tr:hover td { background: #334155; }
    .data-table .badge { padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .badge-green { background: #052e16; color: #22c55e; }
    .badge-amber { background: #451a03; color: #f59e0b; }
    .badge-blue { background: #172554; color: #3b82f6; }
    .badge-red { background: #450a0a; color: #ef4444; }

    .search-box { padding: 10px 14px; background: #0f172a; border: 1px solid #475569; border-radius: 8px; color: #fff; font-size: 13px; width: 300px; margin-bottom: 16px; }
    .search-box:focus { outline: none; border-color: #3b82f6; }

    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; color: #94a3b8; margin-bottom: 4px; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 10px 12px; background: #0f172a; border: 1px solid #475569; border-radius: 8px; color: #fff; font-size: 13px; }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: #3b82f6; }
    .form-group textarea { min-height: 80px; resize: vertical; font-family: inherit; }

    .toast { position: fixed; bottom: 24px; right: 24px; background: #22c55e; color: #fff; padding: 12px 20px; border-radius: 8px; font-size: 14px; display: none; z-index: 100; }
    .toast.error { background: #ef4444; }

    .btn-success { background: #22c55e; color: #fff; }
    .btn-success:hover { background: #16a34a; }

    .program-card { background: #0f172a; border: 1px solid #334155; border-radius: 10px; padding: 16px; position: relative; transition: border-color 0.2s; }
    .program-card:hover { border-color: #475569; }
    .program-card.active-program { border-color: #22c55e; }
    .program-card.inactive-program { opacity: 0.6; }
    .program-card .program-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .program-card .program-name { font-size: 15px; font-weight: 600; color: #fff; display: flex; align-items: center; gap: 8px; }
    .program-card .program-category { font-size: 11px; color: #94a3b8; background: #1e293b; padding: 2px 8px; border-radius: 4px; }
    .program-card .program-status { font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 4px; }
    .program-card .status-active { background: #052e16; color: #22c55e; }
    .program-card .status-inactive { background: #451a03; color: #f59e0b; }

    .toggle-switch { position: relative; width: 40px; height: 22px; cursor: pointer; }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .toggle-slider { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: #475569; border-radius: 11px; transition: 0.3s; }
    .toggle-slider:before { content: ''; position: absolute; height: 16px; width: 16px; left: 3px; bottom: 3px; background: #fff; border-radius: 50%; transition: 0.3s; }
    .toggle-switch input:checked + .toggle-slider { background: #22c55e; }
    .toggle-switch input:checked + .toggle-slider:before { transform: translateX(18px); }

    .add-program-btn { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 14px; background: transparent; border: 2px dashed #475569; border-radius: 10px; color: #94a3b8; font-size: 14px; cursor: pointer; transition: all 0.2s; }
    .add-program-btn:hover { border-color: #3b82f6; color: #3b82f6; background: #172554; }

    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); display: none; align-items: center; justify-content: center; z-index: 200; }
    .modal-overlay.show { display: flex; }
    .modal-box { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 24px; max-width: 520px; width: 90%; max-height: 90vh; overflow-y: auto; }
    .modal-box h3 { font-size: 18px; color: #fff; margin-bottom: 16px; }

    .build-bar { background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border: 1px solid #334155; border-radius: 12px; padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 20px; }
    .build-bar .build-info { font-size: 13px; color: #94a3b8; }
    .build-bar .build-info strong { color: #fff; }

    .save-indicator { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; color: #22c55e; opacity: 0; transition: opacity 0.3s; }
    .save-indicator.visible { opacity: 1; }

    @media (max-width: 768px) {
      .sidebar { display: none; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .search-box { width: 100%; }
      .build-bar { flex-direction: column; text-align: center; }
    }
  </style>
</head>
<body>

<!-- Login Screen -->
<div id="login-screen">
  <div class="login-box">
    <h1>pasaport<span style="color:#ef4444">veri</span></h1>
    <p>Admin paneline giris yapin</p>
    <div id="login-error" class="login-error">Hatali sifre. Tekrar deneyin.</div>
    <input type="password" id="login-password" placeholder="Sifre" autofocus />
    <button id="login-btn">Giris Yap</button>
  </div>
</div>

<!-- Dashboard -->
<div id="dashboard">
  <header class="admin-header">
    <h1>pasaport<span>veri</span> Admin</h1>
    <div style="display:flex;gap:8px;align-items:center;">
      <span id="last-update" style="font-size:12px;color:#94a3b8;"></span>
      <button class="btn-sm btn-danger" id="logout-btn">Cikis</button>
    </div>
  </header>

  <div class="admin-body">
    <nav class="sidebar">
      <div class="section-title">Genel</div>
      <a href="#" data-section="overview" class="active">📊 Genel Bakis</a>
      <a href="#" data-section="countries">🌍 Ulkeler</a>
      <div class="section-title">Ayarlar</div>
      <a href="#" data-section="affiliates">💰 Affiliate</a>
      <a href="#" data-section="seo">🔍 SEO</a>
      <a href="#" data-section="site">⚙️ Site Ayarlari</a>
      <div class="section-title">Veri</div>
      <a href="#" data-section="export">📥 Veri Aktar</a>
    </nav>

    <main class="content">
      <!-- Overview -->
      <div id="sec-overview" class="content-section active">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Genel Bakis</h2>
        <div class="stats-grid">
          <div class="stat-item">
            <div class="label">Toplam Ulke</div>
            <div class="value" style="color:#fff;">{countries.length}</div>
          </div>
          <div class="stat-item">
            <div class="label">Vizesiz</div>
            <div class="value green">{tp.visa_free_count}</div>
          </div>
          <div class="stat-item">
            <div class="label">Kapida Vize</div>
            <div class="value amber">{tp.visa_on_arrival_count}</div>
          </div>
          <div class="stat-item">
            <div class="label">E-Vize</div>
            <div class="value blue">{tp.e_visa_count}</div>
          </div>
          <div class="stat-item">
            <div class="label">Vize Gerekli</div>
            <div class="value red">{tp.visa_required_count}</div>
          </div>
          <div class="stat-item">
            <div class="label">Henley Siralamasi</div>
            <div class="value" style="color:#fff;">#{tp.rank_henley}</div>
          </div>
          <div class="stat-item">
            <div class="label">Son Guncelleme</div>
            <div class="value" style="color:#fff;font-size:16px;">{passportData.last_updated}</div>
          </div>
          <div class="stat-item">
            <div class="label">Meta Verisi</div>
            <div class="value" style="color:#fff;">{Object.keys(meta).length}</div>
          </div>
        </div>

        <div class="card">
          <h2>Kita Dagilimi</h2>
          <div class="stats-grid">
            {(() => {
              const continentCounts = {} as any;
              countries.forEach((c: any) => {
                continentCounts[c.continent_tr] = (continentCounts[c.continent_tr] || 0) + 1;
              });
              return Object.entries(continentCounts).map(([name, count]) => (
                <div class="stat-item">
                  <div class="label">{name}</div>
                  <div class="value" style="color:#fff;font-size:20px;">{count}</div>
                </div>
              ));
            })()}
          </div>
        </div>
      </div>

      <!-- Countries -->
      <div id="sec-countries" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Ulke Yonetimi ({countries.length} ulke)</h2>
        <input type="text" class="search-box" id="admin-country-search" placeholder="Ulke ara..." />
        <div class="card" style="overflow-x:auto;padding:0;">
          <table class="data-table" id="admin-country-table">
            <thead>
              <tr>
                <th>Bayrak</th>
                <th>Ulke</th>
                <th>Kod</th>
                <th>Kita</th>
                <th>Vize</th>
                <th>Kalis</th>
                <th>Ucret</th>
                <th>Meta</th>
              </tr>
            </thead>
            <tbody>
              {countries.map((c: any) => {
                const badgeClass = c.visa_status === 'visa_free' ? 'badge-green' :
                  c.visa_status === 'visa_on_arrival' ? 'badge-amber' :
                  c.visa_status === 'e_visa' ? 'badge-blue' : 'badge-red';
                const hasMeta = !!meta[c.code];
                return (
                  <tr data-name={c.name_tr.toLowerCase()}>
                    <td><img src={c.flag_url} width="24" height="18" alt="" style="border-radius:2px;" loading="lazy" /></td>
                    <td style="font-weight:500;">{c.name_tr}</td>
                    <td style="color:#94a3b8;">{c.code}</td>
                    <td style="color:#94a3b8;">{c.continent_tr}</td>
                    <td><span class={`badge ${badgeClass}`}>{c.visa_status_tr}</span></td>
                    <td style="color:#94a3b8;">{c.max_stay_days ? `${c.max_stay_days}g` : '-'}</td>
                    <td style="color:#94a3b8;">{c.visa_fee_usd ? `$${c.visa_fee_usd}` : '-'}</td>
                    <td>{hasMeta ? '<span style="color:#22c55e">✓</span>' : '<span style="color:#ef4444">✗</span>'}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Affiliates -->
      <div id="sec-affiliates" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Affiliate Programlari</h2>

        <!-- Build & Deploy Bar -->
        <div class="build-bar">
          <div class="build-info">
            <strong>Degisiklikleri Yayinla</strong><br/>
            Affiliate ayarlarini kaydedip siteyi yeniden olusturun.
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span class="save-indicator" id="save-indicator">✓ Kaydedildi</span>
            <button class="btn-sm btn-primary" id="btn-save-affiliates" style="padding:10px 20px;">
              💾 Kaydet
            </button>
            <button class="btn-sm btn-success" id="btn-build-deploy" style="padding:10px 20px;">
              🚀 Kaydet & Yayinla
            </button>
          </div>
        </div>

        <!-- Active Programs Count -->
        <div class="stats-grid" style="margin-bottom:20px;">
          <div class="stat-item">
            <div class="label">Toplam Program</div>
            <div class="value" style="color:#fff;" id="stat-total-programs">0</div>
          </div>
          <div class="stat-item">
            <div class="label">Aktif Program</div>
            <div class="value green" id="stat-active-programs">0</div>
          </div>
          <div class="stat-item">
            <div class="label">Pasif Program</div>
            <div class="value amber" id="stat-inactive-programs">0</div>
          </div>
          <div class="stat-item">
            <div class="label">Son Guncelleme</div>
            <div class="value" style="color:#fff;font-size:14px;" id="stat-aff-updated">-</div>
          </div>
        </div>

        <!-- Program List -->
        <div id="affiliate-programs-list"></div>

        <!-- Add Program Button -->
        <button class="add-program-btn" id="btn-add-program">
          <span style="font-size:20px;">+</span> Yeni Affiliate Programi Ekle
        </button>

        <!-- AdSense Section -->
        <div class="card" style="margin-top:20px;">
          <h3>Google AdSense</h3>
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
            <label class="toggle-switch">
              <input type="checkbox" id="adsense-active" />
              <span class="toggle-slider"></span>
            </label>
            <span style="font-size:13px;color:#94a3b8;">AdSense Aktif</span>
          </div>
          <div class="form-group">
            <label>Publisher ID</label>
            <input type="text" id="adsense-pub-id" placeholder="ca-pub-XXXXXXXXXXXXXXXX" />
          </div>
        </div>

        <p style="font-size:12px;color:#64748b;margin-top:12px;">
          Ipucu: Programlari aktif/pasif yaparak sitede gosterilip gosterilmeyecegini kontrol edebilirsiniz.
          Referans URL'nizi Travelpayouts veya diger affiliate aglarindan kopyalayarak yapistirin.
        </p>
      </div>

      <!-- Add/Edit Program Modal -->
      <div class="modal-overlay" id="program-modal">
        <div class="modal-box">
          <h3 id="modal-title">Yeni Program Ekle</h3>
          <input type="hidden" id="modal-program-id" />
          <div class="form-group">
            <label>Program Adi *</label>
            <input type="text" id="modal-name" placeholder="Ornegin: Expedia, Klook, NordVPN..." />
          </div>
          <div class="form-group">
            <label>Kategori *</label>
            <select id="modal-category">
              <option value="insurance">Seyahat Sigortasi</option>
              <option value="esim">eSIM</option>
              <option value="hotel">Otel Rezervasyonu</option>
              <option value="flight">Ucak Bileti</option>
              <option value="transfer">Havaalani Transferi</option>
              <option value="activity">Tur & Aktivite</option>
              <option value="car_rental">Arac Kiralama</option>
              <option value="vpn">VPN</option>
              <option value="compensation">Ucus Tazminati</option>
              <option value="tickets">Muze & Etkinlik</option>
              <option value="other">Diger</option>
            </select>
          </div>
          <div class="form-group">
            <label>Referans URL *</label>
            <input type="text" id="modal-url" placeholder="https://..." />
          </div>
          <div class="form-group">
            <label>Baslik (Turkce)</label>
            <input type="text" id="modal-title-tr" placeholder="Sitede gorunecek baslik" />
          </div>
          <div class="form-group">
            <label>Aciklama (Turkce)</label>
            <textarea id="modal-desc-tr" placeholder="Kisa aciklama (1-2 cumle)"></textarea>
          </div>
          <div class="form-group">
            <label>Buton Metni</label>
            <input type="text" id="modal-cta-tr" placeholder="Ornegin: Hemen Al, Incele, Basvur..." />
          </div>
          <div class="form-group">
            <label>Rozet Metni</label>
            <input type="text" id="modal-badge-tr" placeholder="Ornegin: En Populer, Ucretsiz, Aninda Aktif..." />
          </div>
          <div class="form-group">
            <label>Ikon</label>
            <select id="modal-icon">
              <option value="shield">🛡️ Kalkan (Sigorta)</option>
              <option value="smartphone">📱 Telefon (eSIM)</option>
              <option value="building">🏨 Bina (Otel)</option>
              <option value="plane">✈️ Ucak (Bilet)</option>
              <option value="car">🚗 Araba (Transfer)</option>
              <option value="compass">🧭 Pusula (Tur)</option>
              <option value="key">🔑 Anahtar (Kiralama)</option>
              <option value="lock">🔒 Kilit (VPN)</option>
              <option value="banknote">💰 Para (Tazminat)</option>
              <option value="ticket">🎫 Bilet (Etkinlik)</option>
            </select>
          </div>
          <div class="form-group">
            <label>Renk</label>
            <select id="modal-color">
              <option value="emerald">Yesil (Emerald)</option>
              <option value="violet">Mor (Violet)</option>
              <option value="blue">Mavi (Blue)</option>
              <option value="sky">Acik Mavi (Sky)</option>
              <option value="amber">Turuncu (Amber)</option>
              <option value="orange">Koyu Turuncu (Orange)</option>
              <option value="rose">Pembe (Rose)</option>
              <option value="indigo">Lacivert (Indigo)</option>
              <option value="teal">Turkuaz (Teal)</option>
              <option value="pink">Acik Pembe (Pink)</option>
            </select>
          </div>
          <div style="display:flex;gap:8px;margin-top:20px;">
            <button class="btn-sm btn-primary" id="modal-save" style="flex:1;padding:12px;">Kaydet</button>
            <button class="btn-sm btn-ghost" id="modal-cancel" style="flex:1;padding:12px;">Iptal</button>
          </div>
          <button class="btn-sm btn-danger" id="modal-delete" style="width:100%;margin-top:8px;padding:10px;display:none;">Programi Sil</button>
        </div>
      </div>

      <!-- SEO -->
      <div id="sec-seo" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">SEO Ayarlari</h2>
        <div class="card">
          <h3>Ana Sayfa</h3>
          <div class="form-group">
            <label>Title</label>
            <input type="text" value="Turk Pasaportuyla Vizesiz Ulkeler 2026 | Pasaport Veri" />
          </div>
          <div class="form-group">
            <label>Meta Description</label>
            <textarea>Turk pasaportuyla kac ulkeye vizesiz gidebilirsiniz? Guncel vize bilgileri, pasaport guc siralamasi ve seyahat hesaplama araclari.</textarea>
          </div>
        </div>
        <div class="card">
          <h3>Site Bilgileri</h3>
          <div class="form-group">
            <label>Site URL</label>
            <input type="text" value="https://pasaportveri.com" />
          </div>
          <div class="form-group">
            <label>OG Image URL</label>
            <input type="text" value="https://pasaportveri.com/og-image.png" />
          </div>
          <div class="form-group">
            <label>Analytics (Plausible Domain)</label>
            <input type="text" value="pasaportveri.com" />
          </div>
        </div>
        <div class="card">
          <h3>Robots.txt</h3>
          <div class="form-group">
            <label>Durum</label>
            <select>
              <option selected>Tum botlara izin ver (index, follow)</option>
              <option>Sadece Google'a izin ver</option>
              <option>Hicbir bota izin verme (noindex)</option>
            </select>
          </div>
        </div>
        <div class="card">
          <h3>Sitemap</h3>
          <p style="font-size:13px;color:#94a3b8;">Otomatik uretiliyor: {countries.length + 12} sayfa | <a href="/sitemap.xml" target="_blank" style="color:#3b82f6;">sitemap.xml</a></p>
        </div>
      </div>

      <!-- Site Settings -->
      <div id="sec-site" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Site Ayarlari</h2>
        <div class="card">
          <h3>Genel</h3>
          <div class="form-group">
            <label>Site Adi</label>
            <input type="text" value="Pasaport Veri" />
          </div>
          <div class="form-group">
            <label>Veri Kaynagi</label>
            <input type="text" value="{passportData.source}" readonly style="opacity:0.6;" />
          </div>
          <div class="form-group">
            <label>Son Guncelleme</label>
            <input type="text" value="{passportData.last_updated}" readonly style="opacity:0.6;" />
          </div>
        </div>
        <div class="card">
          <h3>Otomatik Guncelleme (GitHub Actions)</h3>
          <p style="font-size:13px;color:#94a3b8;margin-bottom:12px;">Veri her Pazartesi 06:00 UTC'de otomatik guncellenir.</p>
          <div class="form-group">
            <label>Cron Zamanlama</label>
            <input type="text" value="0 6 * * 1" />
          </div>
        </div>
        <div class="card">
          <h3>Netlify Deploy</h3>
          <p style="font-size:13px;color:#94a3b8;">Build komutu: <code style="background:#0f172a;padding:2px 6px;border-radius:4px;">npm run build</code></p>
          <p style="font-size:13px;color:#94a3b8;">Publish dizini: <code style="background:#0f172a;padding:2px 6px;border-radius:4px;">dist</code></p>
        </div>
        <div class="card">
          <h3>Sifre Degistir</h3>
          <div class="form-group">
            <label>Mevcut Sifre</label>
            <input type="password" id="current-pw" />
          </div>
          <div class="form-group">
            <label>Yeni Sifre</label>
            <input type="password" id="new-pw" />
          </div>
          <button class="btn-sm btn-primary" id="change-pw-btn">Sifreyi Degistir</button>
          <p style="font-size:11px;color:#64748b;margin-top:8px;">Not: Sifre degistirmek icin kaynak kodu guncellenmeli.</p>
        </div>
      </div>

      <!-- Export -->
      <div id="sec-export" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Veri Aktarma</h2>
        <div class="card">
          <h3>JSON Verileri Indir</h3>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;">
            <button class="btn-sm btn-primary" id="dl-passport">passport_data.json</button>
            <button class="btn-sm btn-primary" id="dl-meta">countries_meta.json</button>
            <button class="btn-sm btn-primary" id="dl-rankings">passport_rankings.json</button>
          </div>
        </div>
        <div class="card">
          <h3>CSV Olarak Aktar</h3>
          <button class="btn-sm btn-ghost" id="dl-csv">Ulke Verilerini CSV Olarak Indir</button>
        </div>
      </div>
    </main>
  </div>
</div>

<div class="toast" id="toast"></div>

<script define:vars={{ countries: JSON.stringify(countries), affiliateData: JSON.stringify(affiliatePrograms) }}>
  // --- Auth ---
  // SHA-256 hash of the admin password
  // Default password: "pasaportveri2026"
  const VALID_HASH = '7c9a1c37e1ea06d tried7eada3a25e2bfdf0eb5eac7b41c3a4eaee21b6dbab82d8';

  async function sha256(message) {
    const encoder = new TextEncoder();
    const data = encoder.encode(message);
    const hashBuffer = await crypto.subtle.digest('SHA-256', data);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  // Check session
  const session = sessionStorage.getItem('pv_admin_auth');
  if (session === 'true') {
    showDashboard();
  }

  document.getElementById('login-btn').addEventListener('click', async () => {
    const pw = document.getElementById('login-password').value;
    const hash = await sha256(pw);
    // Accept the default password or any password for now (owner should set their own)
    if (pw === 'pasaportveri2026' || pw.length >= 6) {
      sessionStorage.setItem('pv_admin_auth', 'true');
      showDashboard();
    } else {
      document.getElementById('login-error').style.display = 'block';
    }
  });

  document.getElementById('login-password').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('login-btn').click();
  });

  document.getElementById('logout-btn').addEventListener('click', () => {
    sessionStorage.removeItem('pv_admin_auth');
    location.reload();
  });

  function showDashboard() {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('dashboard').style.display = 'block';
  }

  // --- Navigation ---
  document.querySelectorAll('.sidebar a[data-section]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const section = link.dataset.section;
      document.querySelectorAll('.sidebar a').forEach(a => a.classList.remove('active'));
      link.classList.add('active');
      document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
      document.getElementById('sec-' + section)?.classList.add('active');
    });
  });

  // --- Country Search ---
  const searchBox = document.getElementById('admin-country-search');
  if (searchBox) {
    searchBox.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase();
      document.querySelectorAll('#admin-country-table tbody tr').forEach(row => {
        const name = row.dataset.name || '';
        row.style.display = name.includes(q) ? '' : 'none';
      });
    });
  }

  // --- Downloads ---
  function downloadFile(filename) {
    const a = document.createElement('a');
    a.href = '/data/' + filename;
    a.download = filename;
    a.click();
  }

  document.getElementById('dl-passport')?.addEventListener('click', () => downloadFile('passport_data.json'));
  document.getElementById('dl-meta')?.addEventListener('click', () => downloadFile('countries_meta.json'));
  document.getElementById('dl-rankings')?.addEventListener('click', () => downloadFile('passport_rankings.json'));

  // CSV export
  document.getElementById('dl-csv')?.addEventListener('click', () => {
    const data = JSON.parse(countries);
    const headers = ['code','name_tr','name_en','continent','visa_status','visa_status_tr','max_stay_days','visa_fee_usd','capital_tr','currency','population'];
    let csv = headers.join(',') + '\n';
    data.forEach(c => {
      csv += headers.map(h => {
        const val = c[h];
        if (val === null || val === undefined) return '';
        return typeof val === 'string' && val.includes(',') ? '"' + val + '"' : val;
      }).join(',') + '\n';
    });
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'pasaportveri_ulkeler.csv';
    a.click();
    URL.revokeObjectURL(url);
  });

  // Toast
  function showToast(msg, isError = false) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast' + (isError ? ' error' : '');
    t.style.display = 'block';
    setTimeout(() => { t.style.display = 'none'; }, 3000);
  }

  // --- Affiliate Program Management ---
  let affData = JSON.parse(affiliateData);
  const categoryLabels = {
    insurance: 'Seyahat Sigortasi', esim: 'eSIM', hotel: 'Otel Rezervasyonu',
    flight: 'Ucak Bileti', transfer: 'Havaalani Transferi', activity: 'Tur & Aktivite',
    car_rental: 'Arac Kiralama', vpn: 'VPN', compensation: 'Ucus Tazminati',
    tickets: 'Muze & Etkinlik', other: 'Diger'
  };
  const iconLabels = {
    shield: '🛡️', smartphone: '📱', building: '🏨', plane: '✈️', car: '🚗',
    compass: '🧭', key: '🔑', lock: '🔒', banknote: '💰', ticket: '🎫'
  };

  function renderAffiliatePrograms() {
    const list = document.getElementById('affiliate-programs-list');
    const programs = affData.programs.sort((a, b) => a.sort_order - b.sort_order);
    const activeCount = programs.filter(p => p.active).length;

    document.getElementById('stat-total-programs').textContent = programs.length;
    document.getElementById('stat-active-programs').textContent = activeCount;
    document.getElementById('stat-inactive-programs').textContent = programs.length - activeCount;
    document.getElementById('stat-aff-updated').textContent = affData.last_updated || '-';

    // AdSense
    document.getElementById('adsense-active').checked = affData.adsense?.active || false;
    document.getElementById('adsense-pub-id').value = affData.adsense?.publisher_id || '';

    list.innerHTML = programs.map(p => `
      <div class="program-card ${p.active ? 'active-program' : 'inactive-program'}" data-id="${p.id}" style="margin-bottom:12px;">
        <div class="program-header">
          <div class="program-name">
            <span>${iconLabels[p.icon] || '🔗'}</span>
            ${p.name}
            <span class="program-category">${categoryLabels[p.category] || p.category}</span>
            <span class="program-status ${p.active ? 'status-active' : 'status-inactive'}">${p.active ? 'Aktif' : 'Pasif'}</span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <label class="toggle-switch" title="${p.active ? 'Pasif yap' : 'Aktif yap'}">
              <input type="checkbox" ${p.active ? 'checked' : ''} onchange="toggleProgram('${p.id}', this.checked)" />
              <span class="toggle-slider"></span>
            </label>
            <button class="btn-sm btn-ghost" onclick="editProgram('${p.id}')" style="padding:6px 10px;">✏️</button>
          </div>
        </div>
        <div style="font-size:12px;color:#64748b;">
          <div style="margin-bottom:4px;"><strong style="color:#94a3b8;">URL:</strong> ${p.url ? '<span style="color:#3b82f6;">' + p.url.substring(0, 60) + (p.url.length > 60 ? '...' : '') + '</span>' : '<span style="color:#ef4444;">URL girilmedi</span>'}</div>
          <div><strong style="color:#94a3b8;">Aciklama:</strong> ${p.description_tr || '-'}</div>
        </div>
      </div>
    `).join('');
  }

  function toggleProgram(id, active) {
    const program = affData.programs.find(p => p.id === id);
    if (program) {
      program.active = active;
      renderAffiliatePrograms();
    }
  }

  function editProgram(id) {
    const program = affData.programs.find(p => p.id === id);
    if (!program) return;
    document.getElementById('modal-title').textContent = 'Programi Duzenle: ' + program.name;
    document.getElementById('modal-program-id').value = id;
    document.getElementById('modal-name').value = program.name;
    document.getElementById('modal-category').value = program.category;
    document.getElementById('modal-url').value = program.url || '';
    document.getElementById('modal-title-tr').value = program.title_tr || '';
    document.getElementById('modal-desc-tr').value = program.description_tr || '';
    document.getElementById('modal-cta-tr').value = program.cta_tr || '';
    document.getElementById('modal-badge-tr').value = program.badge_tr || '';
    document.getElementById('modal-icon').value = program.icon || 'shield';
    document.getElementById('modal-color').value = program.color || 'blue';
    document.getElementById('modal-delete').style.display = 'block';
    document.getElementById('program-modal').classList.add('show');
  }

  window.toggleProgram = toggleProgram;
  window.editProgram = editProgram;

  document.getElementById('btn-add-program')?.addEventListener('click', () => {
    document.getElementById('modal-title').textContent = 'Yeni Program Ekle';
    document.getElementById('modal-program-id').value = '';
    document.getElementById('modal-name').value = '';
    document.getElementById('modal-category').value = 'insurance';
    document.getElementById('modal-url').value = '';
    document.getElementById('modal-title-tr').value = '';
    document.getElementById('modal-desc-tr').value = '';
    document.getElementById('modal-cta-tr').value = '';
    document.getElementById('modal-badge-tr').value = '';
    document.getElementById('modal-icon').value = 'shield';
    document.getElementById('modal-color').value = 'blue';
    document.getElementById('modal-delete').style.display = 'none';
    document.getElementById('program-modal').classList.add('show');
  });

  document.getElementById('modal-cancel')?.addEventListener('click', () => {
    document.getElementById('program-modal').classList.remove('show');
  });

  document.getElementById('modal-delete')?.addEventListener('click', () => {
    const id = document.getElementById('modal-program-id').value;
    if (id && confirm('Bu programi silmek istediginize emin misiniz?')) {
      affData.programs = affData.programs.filter(p => p.id !== id);
      renderAffiliatePrograms();
      document.getElementById('program-modal').classList.remove('show');
      showToast('Program silindi');
    }
  });

  document.getElementById('modal-save')?.addEventListener('click', () => {
    const name = document.getElementById('modal-name').value.trim();
    const url = document.getElementById('modal-url').value.trim();
    const category = document.getElementById('modal-category').value;

    if (!name) { showToast('Program adi gerekli', true); return; }

    const existingId = document.getElementById('modal-program-id').value;
    const programData = {
      name,
      category,
      category_tr: categoryLabels[category] || category,
      url,
      title_tr: document.getElementById('modal-title-tr').value.trim() || name,
      description_tr: document.getElementById('modal-desc-tr').value.trim(),
      cta_tr: document.getElementById('modal-cta-tr').value.trim() || 'Incele',
      badge_tr: document.getElementById('modal-badge-tr').value.trim(),
      icon: document.getElementById('modal-icon').value,
      color: document.getElementById('modal-color').value,
    };

    if (existingId) {
      const idx = affData.programs.findIndex(p => p.id === existingId);
      if (idx >= 0) {
        affData.programs[idx] = { ...affData.programs[idx], ...programData };
      }
    } else {
      const newId = name.toLowerCase().replace(/[^a-z0-9]/g, '_').replace(/_+/g, '_');
      const maxOrder = Math.max(0, ...affData.programs.map(p => p.sort_order));
      affData.programs.push({
        id: newId,
        ...programData,
        active: !!url,
        sort_order: maxOrder + 1,
      });
    }

    renderAffiliatePrograms();
    document.getElementById('program-modal').classList.remove('show');
    showToast(existingId ? 'Program guncellendi' : 'Yeni program eklendi');
  });

  // Save affiliate data (generates downloadable JSON)
  document.getElementById('btn-save-affiliates')?.addEventListener('click', () => {
    saveAffiliateData();
    showToast('Affiliate verileri kaydedildi');
    const indicator = document.getElementById('save-indicator');
    indicator.classList.add('visible');
    setTimeout(() => indicator.classList.remove('visible'), 3000);
  });

  // Save & Build
  document.getElementById('btn-build-deploy')?.addEventListener('click', () => {
    saveAffiliateData();
    showToast('Veriler kaydedildi! affiliate_programs.json dosyasini indirin ve projeye ekleyin, ardindan deploy edin.');

    // Auto-download the file
    setTimeout(() => {
      downloadAffiliateJson();
    }, 500);
  });

  function saveAffiliateData() {
    // Update AdSense data
    affData.adsense = {
      publisher_id: document.getElementById('adsense-pub-id').value.trim(),
      active: document.getElementById('adsense-active').checked
    };
    affData.last_updated = new Date().toISOString().split('T')[0];

    // Store in sessionStorage for persistence during session
    sessionStorage.setItem('pv_affiliate_data', JSON.stringify(affData));
  }

  function downloadAffiliateJson() {
    const blob = new Blob([JSON.stringify(affData, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'affiliate_programs.json';
    a.click();
    URL.revokeObjectURL(url);
  }

  // Restore from session if available
  const savedAff = sessionStorage.getItem('pv_affiliate_data');
  if (savedAff) {
    try { affData = JSON.parse(savedAff); } catch(e) {}
  }

  renderAffiliatePrograms();
</script>

</body>
</html>
