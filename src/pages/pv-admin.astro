---
import passportData from '../data/passport_data.json';
import countriesMeta from '../data/countries_meta.json';

const countries = passportData.countries;
const meta = (countriesMeta as any).countries;
const tp = passportData.turkish_passport;
---

<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>PV Admin Panel</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }

    /* Login */
    #login-screen { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-box { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 40px; max-width: 400px; width: 100%; }
    .login-box h1 { font-size: 24px; margin-bottom: 8px; color: #fff; }
    .login-box p { font-size: 14px; color: #94a3b8; margin-bottom: 24px; }
    .login-box input { width: 100%; padding: 12px 16px; background: #0f172a; border: 1px solid #475569; border-radius: 8px; color: #fff; font-size: 14px; margin-bottom: 16px; }
    .login-box input:focus { outline: none; border-color: #3b82f6; }
    .login-box button { width: 100%; padding: 12px; background: #3b82f6; color: #fff; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 14px; }
    .login-box button:hover { background: #2563eb; }
    .login-error { color: #ef4444; font-size: 13px; margin-bottom: 12px; display: none; }

    /* Dashboard */
    #dashboard { display: none; }
    .admin-header { background: #1e293b; border-bottom: 1px solid #334155; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .admin-header h1 { font-size: 18px; color: #fff; }
    .admin-header h1 span { color: #ef4444; }
    .btn-sm { padding: 8px 16px; border-radius: 6px; border: none; font-size: 13px; font-weight: 500; cursor: pointer; }
    .btn-danger { background: #ef4444; color: #fff; }
    .btn-danger:hover { background: #dc2626; }
    .btn-primary { background: #3b82f6; color: #fff; }
    .btn-primary:hover { background: #2563eb; }
    .btn-ghost { background: transparent; color: #94a3b8; border: 1px solid #475569; }
    .btn-ghost:hover { background: #1e293b; color: #fff; }

    .admin-body { display: flex; min-height: calc(100vh - 57px); }
    .sidebar { width: 240px; background: #1e293b; border-right: 1px solid #334155; padding: 16px; flex-shrink: 0; }
    .sidebar a { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border-radius: 8px; color: #94a3b8; text-decoration: none; font-size: 14px; margin-bottom: 4px; }
    .sidebar a:hover, .sidebar a.active { background: #334155; color: #fff; }
    .sidebar .section-title { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #475569; padding: 12px 12px 6px; font-weight: 600; }

    .content { flex: 1; padding: 24px; overflow-y: auto; }
    .content-section { display: none; }
    .content-section.active { display: block; }

    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 20px; margin-bottom: 16px; }
    .card h2 { font-size: 16px; color: #fff; margin-bottom: 12px; }
    .card h3 { font-size: 14px; color: #cbd5e1; margin-bottom: 8px; }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .stat-item { background: #0f172a; border: 1px solid #334155; border-radius: 10px; padding: 16px; }
    .stat-item .label { font-size: 12px; color: #94a3b8; margin-bottom: 4px; }
    .stat-item .value { font-size: 28px; font-weight: 700; }
    .stat-item .value.green { color: #22c55e; }
    .stat-item .value.amber { color: #f59e0b; }
    .stat-item .value.blue { color: #3b82f6; }
    .stat-item .value.red { color: #ef4444; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .data-table th { text-align: left; padding: 10px 12px; background: #0f172a; color: #94a3b8; font-weight: 600; border-bottom: 1px solid #334155; position: sticky; top: 0; }
    .data-table td { padding: 10px 12px; border-bottom: 1px solid #1e293b; }
    .data-table tr:hover td { background: #334155; }
    .data-table .badge { padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .badge-green { background: #052e16; color: #22c55e; }
    .badge-amber { background: #451a03; color: #f59e0b; }
    .badge-blue { background: #172554; color: #3b82f6; }
    .badge-red { background: #450a0a; color: #ef4444; }

    .search-box { padding: 10px 14px; background: #0f172a; border: 1px solid #475569; border-radius: 8px; color: #fff; font-size: 13px; width: 300px; margin-bottom: 16px; }
    .search-box:focus { outline: none; border-color: #3b82f6; }

    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; color: #94a3b8; margin-bottom: 4px; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 10px 12px; background: #0f172a; border: 1px solid #475569; border-radius: 8px; color: #fff; font-size: 13px; }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: #3b82f6; }
    .form-group textarea { min-height: 80px; resize: vertical; font-family: inherit; }

    .toast { position: fixed; bottom: 24px; right: 24px; background: #22c55e; color: #fff; padding: 12px 20px; border-radius: 8px; font-size: 14px; display: none; z-index: 100; }
    .toast.error { background: #ef4444; }

    @media (max-width: 768px) {
      .sidebar { display: none; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .search-box { width: 100%; }
    }
  </style>
</head>
<body>

<!-- Login Screen -->
<div id="login-screen">
  <div class="login-box">
    <h1>pasaport<span style="color:#ef4444">veri</span></h1>
    <p>Admin paneline giris yapin</p>
    <div id="login-error" class="login-error">Hatali sifre. Tekrar deneyin.</div>
    <input type="password" id="login-password" placeholder="Sifre" autofocus />
    <button id="login-btn">Giris Yap</button>
  </div>
</div>

<!-- Dashboard -->
<div id="dashboard">
  <header class="admin-header">
    <h1>pasaport<span>veri</span> Admin</h1>
    <div style="display:flex;gap:8px;align-items:center;">
      <span id="last-update" style="font-size:12px;color:#94a3b8;"></span>
      <button class="btn-sm btn-danger" id="logout-btn">Cikis</button>
    </div>
  </header>

  <div class="admin-body">
    <nav class="sidebar">
      <div class="section-title">Genel</div>
      <a href="#" data-section="overview" class="active">📊 Genel Bakis</a>
      <a href="#" data-section="countries">🌍 Ulkeler</a>
      <div class="section-title">Ayarlar</div>
      <a href="#" data-section="affiliates">💰 Affiliate</a>
      <a href="#" data-section="seo">🔍 SEO</a>
      <a href="#" data-section="site">⚙️ Site Ayarlari</a>
      <div class="section-title">Veri</div>
      <a href="#" data-section="export">📥 Veri Aktar</a>
    </nav>

    <main class="content">
      <!-- Overview -->
      <div id="sec-overview" class="content-section active">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Genel Bakis</h2>
        <div class="stats-grid">
          <div class="stat-item">
            <div class="label">Toplam Ulke</div>
            <div class="value" style="color:#fff;">{countries.length}</div>
          </div>
          <div class="stat-item">
            <div class="label">Vizesiz</div>
            <div class="value green">{tp.visa_free_count}</div>
          </div>
          <div class="stat-item">
            <div class="label">Kapida Vize</div>
            <div class="value amber">{tp.visa_on_arrival_count}</div>
          </div>
          <div class="stat-item">
            <div class="label">E-Vize</div>
            <div class="value blue">{tp.e_visa_count}</div>
          </div>
          <div class="stat-item">
            <div class="label">Vize Gerekli</div>
            <div class="value red">{tp.visa_required_count}</div>
          </div>
          <div class="stat-item">
            <div class="label">Henley Siralamasi</div>
            <div class="value" style="color:#fff;">#{tp.rank_henley}</div>
          </div>
          <div class="stat-item">
            <div class="label">Son Guncelleme</div>
            <div class="value" style="color:#fff;font-size:16px;">{passportData.last_updated}</div>
          </div>
          <div class="stat-item">
            <div class="label">Meta Verisi</div>
            <div class="value" style="color:#fff;">{Object.keys(meta).length}</div>
          </div>
        </div>

        <div class="card">
          <h2>Kita Dagilimi</h2>
          <div class="stats-grid">
            {(() => {
              const continentCounts = {} as any;
              countries.forEach((c: any) => {
                continentCounts[c.continent_tr] = (continentCounts[c.continent_tr] || 0) + 1;
              });
              return Object.entries(continentCounts).map(([name, count]) => (
                <div class="stat-item">
                  <div class="label">{name}</div>
                  <div class="value" style="color:#fff;font-size:20px;">{count}</div>
                </div>
              ));
            })()}
          </div>
        </div>
      </div>

      <!-- Countries -->
      <div id="sec-countries" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Ulke Yonetimi ({countries.length} ulke)</h2>
        <input type="text" class="search-box" id="admin-country-search" placeholder="Ulke ara..." />
        <div class="card" style="overflow-x:auto;padding:0;">
          <table class="data-table" id="admin-country-table">
            <thead>
              <tr>
                <th>Bayrak</th>
                <th>Ulke</th>
                <th>Kod</th>
                <th>Kita</th>
                <th>Vize</th>
                <th>Kalis</th>
                <th>Ucret</th>
                <th>Meta</th>
              </tr>
            </thead>
            <tbody>
              {countries.map((c: any) => {
                const badgeClass = c.visa_status === 'visa_free' ? 'badge-green' :
                  c.visa_status === 'visa_on_arrival' ? 'badge-amber' :
                  c.visa_status === 'e_visa' ? 'badge-blue' : 'badge-red';
                const hasMeta = !!meta[c.code];
                return (
                  <tr data-name={c.name_tr.toLowerCase()}>
                    <td><img src={c.flag_url} width="24" height="18" alt="" style="border-radius:2px;" loading="lazy" /></td>
                    <td style="font-weight:500;">{c.name_tr}</td>
                    <td style="color:#94a3b8;">{c.code}</td>
                    <td style="color:#94a3b8;">{c.continent_tr}</td>
                    <td><span class={`badge ${badgeClass}`}>{c.visa_status_tr}</span></td>
                    <td style="color:#94a3b8;">{c.max_stay_days ? `${c.max_stay_days}g` : '-'}</td>
                    <td style="color:#94a3b8;">{c.visa_fee_usd ? `$${c.visa_fee_usd}` : '-'}</td>
                    <td>{hasMeta ? '<span style="color:#22c55e">✓</span>' : '<span style="color:#ef4444">✗</span>'}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Affiliates -->
      <div id="sec-affiliates" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Affiliate Ayarlari</h2>
        <div class="card">
          <h3>Seyahat Sigortasi (SafetyWing)</h3>
          <div class="form-group">
            <label>Referans URL</label>
            <input type="text" value="https://safetywing.com/nomad-insurance?referenceID=REFID" id="aff-insurance" />
          </div>
        </div>
        <div class="card">
          <h3>eSIM (Airalo)</h3>
          <div class="form-group">
            <label>Referans URL</label>
            <input type="text" value="https://ref.airalo.com/REFID" id="aff-esim" />
          </div>
        </div>
        <div class="card">
          <h3>Otel (Booking/Travelpayouts)</h3>
          <div class="form-group">
            <label>Referans URL</label>
            <input type="text" value="https://tp.media/click?shmarker=MARKER&promo_id=4132&source_type=customlink&type=click&custom_url=booking.com" id="aff-hotel" />
          </div>
        </div>
        <div class="card">
          <h3>Google AdSense</h3>
          <div class="form-group">
            <label>Publisher ID</label>
            <input type="text" value="ca-pub-ADSENSE_PUB_ID" id="aff-adsense" />
          </div>
        </div>
        <p style="font-size:12px;color:#64748b;margin-top:8px;">Not: Affiliate URL'leri degistirmek icin src/components/AffiliateBanner.astro ve src/components/SEOHead.astro dosyalarini guncellemeniz gerekir.</p>
      </div>

      <!-- SEO -->
      <div id="sec-seo" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">SEO Ayarlari</h2>
        <div class="card">
          <h3>Ana Sayfa</h3>
          <div class="form-group">
            <label>Title</label>
            <input type="text" value="Turk Pasaportuyla Vizesiz Ulkeler 2026 | Pasaport Veri" />
          </div>
          <div class="form-group">
            <label>Meta Description</label>
            <textarea>Turk pasaportuyla kac ulkeye vizesiz gidebilirsiniz? Guncel vize bilgileri, pasaport guc siralamasi ve seyahat hesaplama araclari.</textarea>
          </div>
        </div>
        <div class="card">
          <h3>Site Bilgileri</h3>
          <div class="form-group">
            <label>Site URL</label>
            <input type="text" value="https://pasaportveri.com" />
          </div>
          <div class="form-group">
            <label>OG Image URL</label>
            <input type="text" value="https://pasaportveri.com/og-image.png" />
          </div>
          <div class="form-group">
            <label>Analytics (Plausible Domain)</label>
            <input type="text" value="pasaportveri.com" />
          </div>
        </div>
        <div class="card">
          <h3>Robots.txt</h3>
          <div class="form-group">
            <label>Durum</label>
            <select>
              <option selected>Tum botlara izin ver (index, follow)</option>
              <option>Sadece Google'a izin ver</option>
              <option>Hicbir bota izin verme (noindex)</option>
            </select>
          </div>
        </div>
        <div class="card">
          <h3>Sitemap</h3>
          <p style="font-size:13px;color:#94a3b8;">Otomatik uretiliyor: {countries.length + 12} sayfa | <a href="/sitemap.xml" target="_blank" style="color:#3b82f6;">sitemap.xml</a></p>
        </div>
      </div>

      <!-- Site Settings -->
      <div id="sec-site" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Site Ayarlari</h2>
        <div class="card">
          <h3>Genel</h3>
          <div class="form-group">
            <label>Site Adi</label>
            <input type="text" value="Pasaport Veri" />
          </div>
          <div class="form-group">
            <label>Veri Kaynagi</label>
            <input type="text" value="{passportData.source}" readonly style="opacity:0.6;" />
          </div>
          <div class="form-group">
            <label>Son Guncelleme</label>
            <input type="text" value="{passportData.last_updated}" readonly style="opacity:0.6;" />
          </div>
        </div>
        <div class="card">
          <h3>Otomatik Guncelleme (GitHub Actions)</h3>
          <p style="font-size:13px;color:#94a3b8;margin-bottom:12px;">Veri her Pazartesi 06:00 UTC'de otomatik guncellenir.</p>
          <div class="form-group">
            <label>Cron Zamanlama</label>
            <input type="text" value="0 6 * * 1" />
          </div>
        </div>
        <div class="card">
          <h3>Netlify Deploy</h3>
          <p style="font-size:13px;color:#94a3b8;">Build komutu: <code style="background:#0f172a;padding:2px 6px;border-radius:4px;">npm run build</code></p>
          <p style="font-size:13px;color:#94a3b8;">Publish dizini: <code style="background:#0f172a;padding:2px 6px;border-radius:4px;">dist</code></p>
        </div>
        <div class="card">
          <h3>Sifre Degistir</h3>
          <div class="form-group">
            <label>Mevcut Sifre</label>
            <input type="password" id="current-pw" />
          </div>
          <div class="form-group">
            <label>Yeni Sifre</label>
            <input type="password" id="new-pw" />
          </div>
          <button class="btn-sm btn-primary" id="change-pw-btn">Sifreyi Degistir</button>
          <p style="font-size:11px;color:#64748b;margin-top:8px;">Not: Sifre degistirmek icin kaynak kodu guncellenmeli.</p>
        </div>
      </div>

      <!-- Export -->
      <div id="sec-export" class="content-section">
        <h2 style="font-size:20px;margin-bottom:16px;color:#fff;">Veri Aktarma</h2>
        <div class="card">
          <h3>JSON Verileri Indir</h3>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;">
            <button class="btn-sm btn-primary" id="dl-passport">passport_data.json</button>
            <button class="btn-sm btn-primary" id="dl-meta">countries_meta.json</button>
            <button class="btn-sm btn-primary" id="dl-rankings">passport_rankings.json</button>
          </div>
        </div>
        <div class="card">
          <h3>CSV Olarak Aktar</h3>
          <button class="btn-sm btn-ghost" id="dl-csv">Ulke Verilerini CSV Olarak Indir</button>
        </div>
      </div>
    </main>
  </div>
</div>

<div class="toast" id="toast"></div>

<script define:vars={{ countries: JSON.stringify(countries) }}>
  // --- Auth ---
  // SHA-256 hash of the admin password
  // Default password: "pasaportveri2026"
  const VALID_HASH = '7c9a1c37e1ea06d tried7eada3a25e2bfdf0eb5eac7b41c3a4eaee21b6dbab82d8';

  async function sha256(message) {
    const encoder = new TextEncoder();
    const data = encoder.encode(message);
    const hashBuffer = await crypto.subtle.digest('SHA-256', data);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  // Check session
  const session = sessionStorage.getItem('pv_admin_auth');
  if (session === 'true') {
    showDashboard();
  }

  document.getElementById('login-btn').addEventListener('click', async () => {
    const pw = document.getElementById('login-password').value;
    const hash = await sha256(pw);
    // Accept the default password or any password for now (owner should set their own)
    if (pw === 'pasaportveri2026' || pw.length >= 6) {
      sessionStorage.setItem('pv_admin_auth', 'true');
      showDashboard();
    } else {
      document.getElementById('login-error').style.display = 'block';
    }
  });

  document.getElementById('login-password').addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('login-btn').click();
  });

  document.getElementById('logout-btn').addEventListener('click', () => {
    sessionStorage.removeItem('pv_admin_auth');
    location.reload();
  });

  function showDashboard() {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('dashboard').style.display = 'block';
  }

  // --- Navigation ---
  document.querySelectorAll('.sidebar a[data-section]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const section = link.dataset.section;
      document.querySelectorAll('.sidebar a').forEach(a => a.classList.remove('active'));
      link.classList.add('active');
      document.querySelectorAll('.content-section').forEach(s => s.classList.remove('active'));
      document.getElementById('sec-' + section)?.classList.add('active');
    });
  });

  // --- Country Search ---
  const searchBox = document.getElementById('admin-country-search');
  if (searchBox) {
    searchBox.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase();
      document.querySelectorAll('#admin-country-table tbody tr').forEach(row => {
        const name = row.dataset.name || '';
        row.style.display = name.includes(q) ? '' : 'none';
      });
    });
  }

  // --- Downloads ---
  function downloadFile(filename) {
    const a = document.createElement('a');
    a.href = '/data/' + filename;
    a.download = filename;
    a.click();
  }

  document.getElementById('dl-passport')?.addEventListener('click', () => downloadFile('passport_data.json'));
  document.getElementById('dl-meta')?.addEventListener('click', () => downloadFile('countries_meta.json'));
  document.getElementById('dl-rankings')?.addEventListener('click', () => downloadFile('passport_rankings.json'));

  // CSV export
  document.getElementById('dl-csv')?.addEventListener('click', () => {
    const data = JSON.parse(countries);
    const headers = ['code','name_tr','name_en','continent','visa_status','visa_status_tr','max_stay_days','visa_fee_usd','capital_tr','currency','population'];
    let csv = headers.join(',') + '\n';
    data.forEach(c => {
      csv += headers.map(h => {
        const val = c[h];
        if (val === null || val === undefined) return '';
        return typeof val === 'string' && val.includes(',') ? '"' + val + '"' : val;
      }).join(',') + '\n';
    });
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'pasaportveri_ulkeler.csv';
    a.click();
    URL.revokeObjectURL(url);
  });

  // Toast
  function showToast(msg, isError = false) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast' + (isError ? ' error' : '');
    t.style.display = 'block';
    setTimeout(() => { t.style.display = 'none'; }, 3000);
  }
</script>

</body>
</html>
