---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AffiliateBanner from '../../components/AffiliateBanner.astro';
import SponsoredTools from '../../components/SponsoredTools.astro';
import AdSenseSlot from '../../components/AdSenseSlot.astro';
import { getVisaStatusCounts } from '../../utils/visaHelpers';
import { getRelatedCountries, formatPopulation, getStayText, getProcessingText } from '../../utils/countryHelpers';
import { generateCountryMeta, generateCountrySchema, generateBreadcrumbSchema, generateFAQSchema } from '../../utils/seoHelpers';

import passportData from '../../data/passport_data.json';
import countriesMeta from '../../data/countries_meta.json';

export function getStaticPaths() {
  return passportData.countries.map(country => ({
    params: { ulke: country.slug },
    props: { country }
  }));
}

interface Props {
  country: typeof passportData.countries[0];
}

const { country } = Astro.props;
const allCountries = passportData.countries;
const relatedCountries = getRelatedCountries(allCountries, country, 6);
const rawMeta = (countriesMeta as any).countries[country.code] || null;
// Ensure array fields are actually arrays
const meta = rawMeta ? {
  ...rawMeta,
  travel_tips_tr: Array.isArray(rawMeta.travel_tips_tr) ? rawMeta.travel_tips_tr : [],
  popular_cities_tr: Array.isArray(rawMeta.popular_cities_tr) ? rawMeta.popular_cities_tr : [],
  best_months_tr: Array.isArray(rawMeta.best_months_tr) ? rawMeta.best_months_tr : [],
  time_zones: Array.isArray(rawMeta.time_zones) ? rawMeta.time_zones : [],
} : null;

const seo = generateCountryMeta(country);
// Use meta SEO description if available
if (meta?.seo_description_tr) {
  seo.description = meta.seo_description_tr;
}
const countrySchema = generateCountrySchema(country);
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Ana Sayfa', url: 'https://pasaportveri.com/' },
  { name: 'Ülkeler', url: 'https://pasaportveri.com/vizesiz-ulkeler' },
  { name: country.name_tr, url: seo.canonical }
]);

// Generate FAQ schema for better SEO
const faqs = [
  {
    question: `Türk pasaportuyla ${country.name_tr}'a vize gerekli mi?`,
    answer: country.visa_status === 'visa_free'
      ? `Hayır, Türk pasaportu sahipleri ${country.name_tr}'a vizesiz girebilir. Maksimum kalış süresi ${country.max_stay_days ? country.max_stay_days + ' gündür' : 'belirtilmemiştir'}.`
      : country.visa_status === 'visa_on_arrival'
      ? `${country.name_tr}'a varışta kapıda vize alınabilir.${country.visa_fee_usd ? ' Vize ücreti yaklaşık $' + country.visa_fee_usd + "'dir." : ''}`
      : country.visa_status === 'e_visa'
      ? `${country.name_tr} için online e-vize başvurusu yapılabilir.${country.processing_days ? ' İşlem süresi yaklaşık ' + country.processing_days + ' gündür.' : ''}`
      : `Evet, ${country.name_tr}'a seyahat için önceden vize alınması gerekmektedir.`
  },
  {
    question: `${country.name_tr}'da en fazla kaç gün kalınabilir?`,
    answer: country.max_stay_days
      ? `${country.name_tr}'da maksimum ${country.max_stay_days} gün kalınabilir.`
      : `${country.name_tr} için belirli bir maksimum kalış süresi belirtilmemiştir. Güncel bilgi için büyükelçilik ile iletişime geçin.`
  },
  {
    question: `${country.name_tr} para birimi nedir?`,
    answer: `${country.name_tr}'nin para birimi ${country.currency} (${country.currency_symbol})'dir.`
  }
];
const faqSchema = generateFAQSchema(faqs);

const statusColors: Record<string, string> = {
  visa_free: 'bg-green-100 text-green-800 border-green-200',
  visa_on_arrival: 'bg-amber-100 text-amber-800 border-amber-200',
  e_visa: 'bg-blue-100 text-blue-800 border-blue-200',
  visa_required: 'bg-red-100 text-red-800 border-red-200',
  no_admission: 'bg-gray-100 text-gray-800 border-gray-200'
};

const statusBgGradient: Record<string, string> = {
  visa_free: 'from-green-500 to-green-600',
  visa_on_arrival: 'from-amber-500 to-amber-600',
  e_visa: 'from-blue-500 to-blue-600',
  visa_required: 'from-red-500 to-red-600',
  no_admission: 'from-gray-500 to-gray-600'
};

const statusIcon: Record<string, string> = {
  visa_free: '✓',
  visa_on_arrival: '◉',
  e_visa: '⬡',
  visa_required: '✗',
  no_admission: '⛔'
};
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical} ogImage={seo.ogImage} ogType={seo.ogType} jsonLdArray={[countrySchema, breadcrumbSchema, faqSchema]}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'Ülkeler', href: '/vizesiz-ulkeler' },
      { label: country.name_tr }
    ]} />

    <!-- Hero Card -->
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-8 shadow-sm">
      <div class={`bg-gradient-to-r ${statusBgGradient[country.visa_status] || 'from-slate-500 to-slate-600'} text-white p-6 sm:p-8`}>
        <div class="flex items-center gap-4">
          <img
            src={country.flag_url}
            srcset={`${country.flag_url.replace('w80', 'w160')} 2x`}
            width="72"
            height="54"
            alt={`${country.name_tr} bayrağı`}
            class="rounded-lg shadow-lg"
          />
          <div>
            <h1 class="text-2xl sm:text-3xl font-extrabold">{country.name_tr}</h1>
            <p class="text-white/80 text-sm mt-1">{country.name_en}</p>
          </div>
        </div>
        <div class="mt-6 inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full">
          <span class="text-lg">{statusIcon[country.visa_status]}</span>
          <span class="font-bold text-lg">🇹🇷 Türk Pasaportuyla: {country.visa_status_tr.toUpperCase()}</span>
        </div>
      </div>

      <div class="p-6 sm:p-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
          <div class="bg-slate-50 rounded-lg p-4 text-center">
            <div class="text-xs text-slate-500 mb-1">Vize Durumu</div>
            <span class={`visa-badge ${country.visa_status}`}>{country.visa_status_tr}</span>
          </div>
          <div class="bg-slate-50 rounded-lg p-4 text-center">
            <div class="text-xs text-slate-500 mb-1">Maksimum Kalış</div>
            <div class="font-bold text-slate-900">{getStayText(country.max_stay_days)}</div>
          </div>
          <div class="bg-slate-50 rounded-lg p-4 text-center">
            <div class="text-xs text-slate-500 mb-1">Vize Ücreti</div>
            <div class="font-bold text-slate-900">{country.visa_fee_usd ? `$${country.visa_fee_usd}` : 'Ücretsiz'}</div>
          </div>
          <div class="bg-slate-50 rounded-lg p-4 text-center">
            <div class="text-xs text-slate-500 mb-1">İşlem Süresi</div>
            <div class="font-bold text-slate-900">{getProcessingText(country.processing_days)}</div>
          </div>
        </div>

        {country.visa_type_details && (
          <div class="bg-slate-50 rounded-lg p-4 mb-6">
            <div class="text-sm text-slate-600">
              <span class="font-semibold">Vize Türü:</span> {country.visa_type_details}
            </div>
          </div>
        )}

        {country.notes_tr && (
          <div class="prose prose-sm max-w-none mb-6">
            <p class="text-slate-700 leading-relaxed">{country.notes_tr}</p>
          </div>
        )}

        {(country.official_embassy_url || country.application_url) && (
          <div class="flex flex-wrap gap-3">
            {country.official_embassy_url && (
              <a
                href={country.official_embassy_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center px-4 py-2 bg-secondary text-white text-sm font-medium rounded-lg hover:bg-slate-800 transition-colors"
              >
                🏛️ Resmi Büyükelçilik
              </a>
            )}
            {country.application_url && (
              <a
                href={country.application_url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-colors"
              >
                📝 Başvuru Yap
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <!-- Left Column (2/3) -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Country Info -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <h2 class="text-lg font-bold text-slate-900 mb-4">Ülke Bilgileri</h2>
          <dl class="grid grid-cols-2 gap-4 text-sm">
            <div>
              <dt class="text-slate-500">Başkent</dt>
              <dd class="font-medium text-slate-900">{country.capital_tr}</dd>
            </div>
            <div>
              <dt class="text-slate-500">Nüfus</dt>
              <dd class="font-medium text-slate-900">{formatPopulation(country.population)}</dd>
            </div>
            <div>
              <dt class="text-slate-500">Dil</dt>
              <dd class="font-medium text-slate-900">{country.language_tr}</dd>
            </div>
            <div>
              <dt class="text-slate-500">Para Birimi</dt>
              <dd class="font-medium text-slate-900">{country.currency} ({country.currency_symbol})</dd>
            </div>
            <div>
              <dt class="text-slate-500">Kıta</dt>
              <dd class="font-medium text-slate-900">{country.continent_tr}</dd>
            </div>
            <div>
              <dt class="text-slate-500">Seyahat Tavsiyesi</dt>
              <dd class={`font-medium ${country.advisory_level <= 2 ? 'text-green-600' : country.advisory_level === 3 ? 'text-amber-600' : 'text-red-600'}`}>
                {country.advisory_text_tr}
              </dd>
            </div>
            {meta?.calling_code && (
              <div>
                <dt class="text-slate-500">Telefon Kodu</dt>
                <dd class="font-medium text-slate-900">{meta.calling_code}</dd>
              </div>
            )}
            {meta?.drives_on && (
              <div>
                <dt class="text-slate-500">Trafik Yönü</dt>
                <dd class="font-medium text-slate-900">{meta.drives_on === 'right' ? 'Sağ' : 'Sol'}</dd>
              </div>
            )}
            {meta?.electrical_plug && (
              <div>
                <dt class="text-slate-500">Priz Tipi</dt>
                <dd class="font-medium text-slate-900">{meta.electrical_plug} ({meta.voltage})</dd>
              </div>
            )}
            {meta?.time_zones && (
              <div>
                <dt class="text-slate-500">Saat Dilimi</dt>
                <dd class="font-medium text-slate-900">{meta.time_zones.join(', ')}</dd>
              </div>
            )}
            {meta?.climate_tr && (
              <div class="col-span-2">
                <dt class="text-slate-500">İklim</dt>
                <dd class="font-medium text-slate-900">{meta.climate_tr}</dd>
              </div>
            )}
          </dl>
        </div>

        <!-- Popular Cities -->
        {meta?.popular_cities_tr && meta.popular_cities_tr.length > 0 && (
          <div class="bg-white rounded-xl border border-slate-200 p-6">
            <h2 class="text-lg font-bold text-slate-900 mb-4">Popüler Şehirler</h2>
            <div class="flex flex-wrap gap-2">
              {meta.popular_cities_tr.map((city: string) => (
                <span class="inline-flex items-center px-3 py-1.5 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">
                  📍 {city}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Best Months to Visit -->
        {meta?.best_months_tr && meta.best_months_tr.length > 0 && (
          <div class="bg-white rounded-xl border border-slate-200 p-6">
            <h2 class="text-lg font-bold text-slate-900 mb-4">En İyi Ziyaret Zamanı</h2>
            <div class="flex flex-wrap gap-2">
              {meta.best_months_tr.map((month: string) => (
                <span class="inline-flex items-center px-3 py-1.5 bg-blue-50 text-blue-700 rounded-full text-sm font-medium">
                  📅 {month}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Travel Tips -->
        {meta?.travel_tips_tr && meta.travel_tips_tr.length > 0 && (
          <div class="bg-white rounded-xl border border-slate-200 p-6">
            <h2 class="text-lg font-bold text-slate-900 mb-4">Seyahat İpuçları</h2>
            <ul class="space-y-3">
              {meta.travel_tips_tr.map((tip: string) => (
                <li class="flex items-start gap-2 text-sm text-slate-700">
                  <span class="text-secondary font-bold mt-0.5 flex-shrink-0">💡</span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Visa Application Info -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <h2 class="text-lg font-bold text-slate-900 mb-4">Vize Başvuru Bilgileri</h2>
          {country.visa_status === 'visa_required' && (
            <div class="space-y-4 text-sm text-slate-700">
              <p>{country.name_tr} için vize başvurusu yapmanız gerekmektedir. Başvuru süreci genellikle şu adımlardan oluşur:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>Vize başvuru formunu doldurun</li>
                <li>Gerekli belgeleri hazırlayın (pasaport, fotoğraf, seyahat sigortası, konaklama ve uçuş rezervasyonu)</li>
                <li>Randevu alın</li>
                <li>Biyometrik verilerinizi verin</li>
                <li>Vize sonucunu bekleyin (ortalama {getProcessingText(country.processing_days)})</li>
              </ol>
              {country.visa_fee_usd && (
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-blue-800">
                  <strong>Vize Ücreti:</strong> ${country.visa_fee_usd} (yaklaşık)
                </div>
              )}
              <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-amber-800">
                <strong>Önemli:</strong> Vize başvurunuzu seyahat tarihinizden en az {country.processing_days ? `${country.processing_days} gün` : '2-3 hafta'} önce yapmanız önerilir.
              </div>
            </div>
          )}
          {country.visa_status === 'e_visa' && (
            <div class="space-y-4 text-sm text-slate-700">
              <p>{country.name_tr} için e-vize başvurusu online olarak yapılabilmektedir.</p>
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                <h4 class="font-semibold text-blue-900 mb-2">E-Vize Başvuru Adımları:</h4>
                <ol class="list-decimal list-inside space-y-1 text-blue-800">
                  <li>Resmi e-vize web sitesine gidin</li>
                  <li>Başvuru formunu doldurun</li>
                  <li>Gerekli belgeleri yükleyin (pasaport kopyası, fotoğraf)</li>
                  <li>Vize ücretini online ödeyin{country.visa_fee_usd ? ` ($${country.visa_fee_usd})` : ''}</li>
                  <li>E-vizenizi e-posta ile alın</li>
                </ol>
              </div>
              {country.application_url && (
                <a
                  href={country.application_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors"
                >
                  E-Vize Basvurusu Yap &rarr;
                </a>
              )}
            </div>
          )}
          {country.visa_status === 'visa_on_arrival' && (
            <div class="space-y-4 text-sm text-slate-700">
              <p>{country.name_tr}'a vardığınızda havalimanında vize alabilirsiniz. Maksimum kalış süresi {getStayText(country.max_stay_days)}.</p>
              <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                <h4 class="font-semibold text-green-900 mb-2">Kapıda Vize İçin Gerekenler:</h4>
                <ul class="space-y-1 text-green-800">
                  <li>✓ Geçerli pasaport (en az 6 ay süreli)</li>
                  <li>✓ Dönüş bileti</li>
                  <li>✓ Otel rezervasyonu</li>
                  <li>✓ Yeterli nakit (USD/EUR){country.visa_fee_usd ? ` - Vize ücreti: $${country.visa_fee_usd}` : ''}</li>
                  <li>✓ Vesikalık fotoğraf (bazı ülkelerde)</li>
                </ul>
              </div>
              <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-amber-800">
                <strong>Dikkat:</strong> Kapıda vize her zaman garanti değildir. Belgeleri eksiksiz bulundurun.
              </div>
            </div>
          )}
          {country.visa_status === 'visa_free' && (
            <div class="space-y-4 text-sm text-slate-700">
              <p>{country.name_tr}'a vizesiz giriş yapabilirsiniz. Maksimum kalış süreniz <strong>{getStayText(country.max_stay_days)}</strong>.</p>
              <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                <h4 class="font-semibold text-green-900 mb-2">Giriş İçin Gerekenler:</h4>
                <ul class="space-y-1 text-green-800">
                  <li>✓ Geçerli Türk pasaportu (en az 6 ay süreli)</li>
                  <li>✓ Dönüş bileti (tavsiye edilir)</li>
                  <li>✓ Konaklama bilgisi</li>
                  <li>✓ Yeterli maddi kaynak</li>
                </ul>
              </div>
              <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-green-800">
                <strong>İyi haber:</strong> Vize başvurusu yapmanıza gerek yok. Pasaportunuz ve dönüş biletinizle giriş yapabilirsiniz.
              </div>
            </div>
          )}
        </div>

        <!-- FAQ Section for SEO -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <h2 class="text-lg font-bold text-slate-900 mb-4">Sık Sorulan Sorular</h2>
          <div class="space-y-4">
            {faqs.map(faq => (
              <details class="group border border-slate-200 rounded-lg">
                <summary class="flex items-center justify-between cursor-pointer p-4 text-sm font-medium text-slate-900 hover:bg-slate-50 rounded-lg">
                  <span>{faq.question}</span>
                  <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-4 pb-4 text-sm text-slate-600">
                  {faq.answer}
                </div>
              </details>
            ))}
          </div>
        </div>

        <!-- Affiliate Banners - Dynamic from JSON -->
        <AffiliateBanner category="insurance" countryName={country.name_tr} />
        <AffiliateBanner category="esim" countryName={country.name_tr} />

        <!-- Sponsored Tools Grid -->
        <SponsoredTools countryName={country.name_tr} variant="grid" limit={6} />

        <AdSenseSlot slot="ADSENSE_SLOT_COUNTRY_1" format="rectangle" />
      </div>

      <!-- Right Column (1/3) Sidebar -->
      <aside class="space-y-6">
        <!-- Quick Info -->
        <div class="bg-white rounded-xl border border-slate-200 p-6 sticky top-20">
          <h3 class="font-bold text-slate-900 mb-3">Hızlı Bilgiler</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex items-center gap-2">
              <span class="text-slate-400">🏙️</span>
              <span class="text-slate-600">Başkent: <strong>{country.capital_tr}</strong></span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-slate-400">💰</span>
              <span class="text-slate-600">Para: <strong>{country.currency} ({country.currency_symbol})</strong></span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-slate-400">🗣️</span>
              <span class="text-slate-600">Dil: <strong>{country.language_tr}</strong></span>
            </li>
            <li class="flex items-center gap-2">
              <span class="text-slate-400">👥</span>
              <span class="text-slate-600">Nüfus: <strong>{formatPopulation(country.population)}</strong></span>
            </li>
            {meta?.calling_code && (
              <li class="flex items-center gap-2">
                <span class="text-slate-400">📞</span>
                <span class="text-slate-600">Telefon: <strong>{meta.calling_code}</strong></span>
              </li>
            )}
            {meta?.drives_on && (
              <li class="flex items-center gap-2">
                <span class="text-slate-400">🚗</span>
                <span class="text-slate-600">Trafik: <strong>{meta.drives_on === 'right' ? 'Sağ' : 'Sol'}</strong></span>
              </li>
            )}
            {meta?.electrical_plug && (
              <li class="flex items-center gap-2">
                <span class="text-slate-400">🔌</span>
                <span class="text-slate-600">Priz: <strong>{meta.electrical_plug}</strong></span>
              </li>
            )}
          </ul>
        </div>

        <!-- Related Countries -->
        <div class="bg-white rounded-xl border border-slate-200 p-6">
          <h3 class="font-bold text-slate-900 mb-3">İlgili Ülkeler</h3>
          <div class="space-y-2">
            {relatedCountries.map(rc => (
              <a
                href={`/ulkeler/${rc.slug}`}
                class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-50 transition-colors"
              >
                <img
                  src={rc.flag_url}
                  width="28"
                  height="21"
                  alt={`${rc.name_tr} bayrağı`}
                  loading="lazy"
                  class="rounded"
                />
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-medium text-slate-900 truncate">{rc.name_tr}</div>
                  <span class={`visa-badge ${rc.visa_status} text-[10px] px-2 py-0.5`}>{rc.visa_status_tr}</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Compact Affiliate Links - Dynamic from JSON -->
        <SponsoredTools countryName={country.name_tr} variant="compact" limit={5} />

        <AdSenseSlot slot="ADSENSE_SLOT_COUNTRY_2" format="responsive" />
      </aside>
    </div>
  </div>
</BaseLayout>
