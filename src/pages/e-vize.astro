---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AffiliateBanner from '../components/AffiliateBanner.astro';
import AdSenseSlot from '../components/AdSenseSlot.astro';
import { sortCountries } from '../utils/visaHelpers';
import { generateCategoryMeta } from '../utils/seoHelpers';

import passportData from '../data/passport_data.json';

const allCountries = passportData.countries;
const eVisaCountries = sortCountries(
  allCountries.filter(c => c.visa_status === 'e_visa'),
  'name'
);
const seo = generateCategoryMeta('e-vize');
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical} ogImage={seo.ogImage}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'E-Vize' }
    ]} />

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-3">
        Türk Pasaportuyla E-Vize Alınabilen Ülkeler (2026)
      </h1>
      <p class="text-lg text-slate-600">
        Toplam <strong class="text-blue-600">{eVisaCountries.length} ülkeye</strong> e-vize ile giriş yapabilirsiniz.
      </p>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 mb-8">
      <p class="text-blue-800 text-sm">
        <strong>ℹ️ E-Vize Nedir?</strong> E-vize (elektronik vize), online olarak başvurusu yapılan ve genellikle e-posta ile teslim alınan dijital vizedir. Seyahatten önce başvuru yapmanız gerekmektedir.
      </p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-8">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="text-left px-4 py-3 font-semibold text-slate-700" scope="col">Bayrak</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700" scope="col">Ülke</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700 hidden sm:table-cell" scope="col">Ücret</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700 hidden md:table-cell" scope="col">İşlem Süresi</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700 hidden lg:table-cell" scope="col">Kalış Süresi</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700" scope="col"></th>
          </tr>
        </thead>
        <tbody>
          {eVisaCountries.map(country => (
            <tr class="table-row border-b border-slate-100 last:border-0">
              <td class="px-4 py-3">
                <img src={country.flag_url} width="28" height="21" alt="" loading="lazy" class="rounded" />
              </td>
              <td class="px-4 py-3">
                <a href={`/ulkeler/${country.slug}`} class="font-medium text-slate-900 hover:text-primary transition-colors">
                  {country.name_tr}
                </a>
              </td>
              <td class="px-4 py-3 text-slate-600 hidden sm:table-cell">
                {country.visa_fee_usd ? `$${country.visa_fee_usd}` : 'Ücretsiz'}
              </td>
              <td class="px-4 py-3 text-slate-600 hidden md:table-cell">
                {country.processing_days ? `~${country.processing_days} gün` : 'Hızlı'}
              </td>
              <td class="px-4 py-3 text-slate-600 hidden lg:table-cell">
                {country.max_stay_days ? `${country.max_stay_days} gün` : '-'}
              </td>
              <td class="px-4 py-3">
                {country.application_url ? (
                  <a href={country.application_url} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-600 hover:underline">
                    Başvur →
                  </a>
                ) : (
                  <a href={`/ulkeler/${country.slug}`} class="text-sm text-secondary hover:underline">Detay →</a>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-6 mb-8">
      <h2 class="text-lg font-bold text-slate-900 mb-4">E-Vize Başvuru İpuçları</h2>
      <ul class="space-y-3 text-sm text-slate-700">
        <li class="flex items-start gap-2">
          <span class="text-blue-500 font-bold mt-0.5">•</span>
          <span>E-vize başvurunuzu seyahatten <strong>en az 1-2 hafta önce</strong> yapın.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-500 font-bold mt-0.5">•</span>
          <span>Pasaportunuzun taranmış bir kopyasını hazır bulundurun.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-500 font-bold mt-0.5">•</span>
          <span>Onaylanan e-vizeyi <strong>yazdırın</strong> veya telefonunuzda saklayın.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-500 font-bold mt-0.5">•</span>
          <span>Ödeme için uluslararası geçerli bir <strong>kredi kartı</strong> kullanın.</span>
        </li>
      </ul>
    </div>

    <AdSenseSlot slot="ADSENSE_SLOT_EVIZA_1" format="rectangle" />
    <AffiliateBanner type="insurance" />
  </div>
</BaseLayout>
