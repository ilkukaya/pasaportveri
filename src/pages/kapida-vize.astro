---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AffiliateBanner from '../components/AffiliateBanner.astro';
import AdSenseSlot from '../components/AdSenseSlot.astro';
import { sortCountries } from '../utils/visaHelpers';
import { generateCategoryMeta } from '../utils/seoHelpers';

import passportData from '../data/passport_data.json';

const allCountries = passportData.countries;
const voaCountries = sortCountries(
  allCountries.filter(c => c.visa_status === 'visa_on_arrival'),
  'name'
);
const seo = generateCategoryMeta('kapida-vize');
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical} ogImage={seo.ogImage}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb items={[
      { label: 'Ana Sayfa', href: '/' },
      { label: 'Kapıda Vize' }
    ]} />

    <div class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-3">
        Türk Pasaportuyla Kapıda Vize Alınabilen Ülkeler (2026)
      </h1>
      <p class="text-lg text-slate-600">
        Toplam <strong class="text-amber-600">{voaCountries.length} ülkeye</strong> kapıda vize ile giriş yapabilirsiniz.
      </p>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 mb-8">
      <p class="text-amber-800 text-sm">
        <strong>⚠️ Önemli:</strong> Kapıda vize her zaman garanti değildir ve reddedilebilir. Seyahat önceden ilgili büyükelçilik veya konsolosluktan güncel bilgi alınız. Yanınızda yeterli nakit (USD/EUR), dönüş bileti ve otel rezervasyonu bulundurun.
      </p>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-8">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="text-left px-4 py-3 font-semibold text-slate-700" scope="col">Bayrak</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700" scope="col">Ülke</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700 hidden sm:table-cell" scope="col">Ücret</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700 hidden md:table-cell" scope="col">Kalış Süresi</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-700" scope="col"></th>
          </tr>
        </thead>
        <tbody>
          {voaCountries.map(country => (
            <tr class="table-row border-b border-slate-100 last:border-0">
              <td class="px-4 py-3">
                <img src={country.flag_url} width="28" height="21" alt="" loading="lazy" class="rounded" />
              </td>
              <td class="px-4 py-3">
                <a href={`/ulkeler/${country.slug}`} class="font-medium text-slate-900 hover:text-primary transition-colors">
                  {country.name_tr}
                </a>
              </td>
              <td class="px-4 py-3 text-slate-600 hidden sm:table-cell">
                {country.visa_fee_usd ? `$${country.visa_fee_usd}` : 'Ücretsiz'}
              </td>
              <td class="px-4 py-3 text-slate-600 hidden md:table-cell">
                {country.max_stay_days ? `${country.max_stay_days} gün` : '-'}
              </td>
              <td class="px-4 py-3">
                <a href={`/ulkeler/${country.slug}`} class="text-sm text-secondary hover:underline">Detay →</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-6 mb-8">
      <h2 class="text-lg font-bold text-slate-900 mb-4">Kapıda Vize İçin Pratik İpuçları</h2>
      <ul class="space-y-3 text-sm text-slate-700">
        <li class="flex items-start gap-2">
          <span class="text-amber-500 font-bold mt-0.5">•</span>
          <span>Yanınızda yeterli miktarda <strong>nakit USD veya EUR</strong> bulundurun. Kredi kartı kabul edilmeyebilir.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-500 font-bold mt-0.5">•</span>
          <span><strong>Dönüş biletinizi</strong> ibraz etmeniz istenebilir.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-500 font-bold mt-0.5">•</span>
          <span><strong>Otel rezervasyonunuzu</strong> yazılı olarak yanınızda bulundurun.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-500 font-bold mt-0.5">•</span>
          <span>Pasaportunuzun <strong>en az 6 ay</strong> geçerli olduğundan emin olun.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-amber-500 font-bold mt-0.5">•</span>
          <span>Bazı ülkeler sadece belirli havalimanlarında kapıda vize vermektedir.</span>
        </li>
      </ul>
    </div>

    <AdSenseSlot slot="ADSENSE_SLOT_KAPIDA_1" format="rectangle" />
    <AffiliateBanner type="insurance" />
  </div>
</BaseLayout>
